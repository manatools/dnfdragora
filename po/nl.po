#: dnfdragora/helpinfo.py:76
msgid ""
"dnfdragora is a DNF frontend, based on Mageia rpmdragora layout and Fedora "
"yumex-dnf interaction with dnfdaemon.<br><br>"
msgstr ""
"dnfdragora is een DNF-frontend gebaseerd op Mageia rpmdragora-indeling en "
"Fedora yumex-dnf-interactie met dnfdaemon. <br><br>"

#: dnfdragora/helpinfo.py:77
msgid ""
"dnfdragora is basically a package manager user interface that allows you to "
"install, update, remove, and search for packages and more.<br><br>"
msgstr ""
" dnfdragora is simpel gezien een interface voor pakketbeheer waarmee "
"pakketten kunnen worden geïnstalleerd, bijgewerkt, verwijderd, gezocht en "
"meer.\n"
"<br><br>"

#: dnfdragora/helpinfo.py:78
msgid ""
"dnfdragora is part of manatools and it is based on manatools.aui so that it "
"can work using Qt (PySide6), GTK 4, or ncurses, i.e. both graphical and "
"textual user interfaces.<br><br>"
msgstr ""
"dnfdragora is onderdeel van manatools en is gebaseerd op manatools.aui, "
"waardoor het kan werken met Qt (PySide6), GTK 4 of ncurses, oftewel met "
"zowel grafische als tekstuele gebruikersinterfaces. <br><br>"

#: dnfdragora/helpinfo.py:79
msgid "dnfdragora window is comprised of:"
msgstr "dnfdragora-venster is opgebouwd uit:"

#: dnfdragora/helpinfo.py:84
msgid "Menu bar content"
msgstr "Menubalk-inhoud"

#: dnfdragora/helpinfo.py:86
msgid "Menu bar contains dnfdragora drop down menus:"
msgstr "Menubalk bevat dropdown-menu's van dnfdragora:"

#: dnfdragora/helpinfo.py:94
msgid "File Menu"
msgstr "Bestandsmenu"

#: dnfdragora/helpinfo.py:96
msgid "<h2>Reset selection</h2>"
msgstr "<h2>Herstel selectie</h2>"

#: dnfdragora/helpinfo.py:97
msgid ""
"This menu removes any flags on packages; if any packages have been selected "
"for installation or removal, they will be reset to their previous status.<br>"
msgstr ""
"Deze menukeuze verwijdert alle vlaggen van pakketten; als er pakketten zijn "
"geselecteerd voor installatie of verwijdering, worden deze teruggezet naar "
"hun vorige status.<br>"

#: dnfdragora/helpinfo.py:98
msgid "<h2>Refresh metadata</h2>"
msgstr "<h2>Ververs metadata</h2>"

#: dnfdragora/helpinfo.py:99
msgid ""
"This menu sends a request to dnfdaemon to force a refresh of all the "
"metadata. This action is asynchronous and requires rebuilding the package "
"information cache.<br>"
msgstr ""
"Deze menukeuze zendt een verzoek naar dnfdaemon om alle metadata te "
"verversen. Deze actie is asynchroon en vereist het opnieuw opbouwen van de "
"cache met pakketinformatie.<br>"

#: dnfdragora/helpinfo.py:100
msgid "<h2>Repositories</h2>"
msgstr "<h2>Pakkettendepots</h2>"

#: dnfdragora/helpinfo.py:101
msgid "This menu opens the Repository Management dialog.<br>"
msgstr ""
"Dit menu opent het dialoogvenster voor het beheren van het pakkettendepot."
"<br>"

#: dnfdragora/helpinfo.py:102
msgid ""
"The dialog lists all configured repositories sorted by name. You can enable "
"or disable each repository using its checkbox. Changes take effect "
"immediately for the current session but are not permanent.<br><br>"
msgstr ""
"In het dialoogvenster worden alle geconfigureerde pakkettendepots op naam "
"weergegeven. U kunt elk pakketdepot in- of uitschakelen via het "
"selectievakje. Wijzigingen worden direct van kracht voor de huidige sessie, "
"maar zijn niet permanent.<br><br>"

#: dnfdragora/helpinfo.py:103
msgid "<b>Filter frame — Show additional repository types</b><br>"
msgstr "<b>Filterkader — Toon aanvullende typen pakketdepots</b><br>"

#: dnfdragora/helpinfo.py:104
msgid ""
"By default the list hides debug-information, source, and testing "
"repositories. Expand the filter frame by checking its title to show three "
"additional checkboxes:<br>"
msgstr ""
"Standaard verbergt de lijst debug-informatie-, broncode- en test-"
"pakketdepots. Vouw het filterkader uit door op de titel te klikken, om drie "
"extra selectievakjes weer te geven:<br>"

#: dnfdragora/helpinfo.py:105 dnfdragora/helpinfo.py:279
#: dnfdragora/helpinfo.py:286 dnfdragora/helpinfo.py:294
#: dnfdragora/helpinfo.py:301
msgid "<ul>"
msgstr "<ul>"

#: dnfdragora/helpinfo.py:106
msgid ""
"<li><b>Debug information</b>: show repositories whose id ends with <i>-"
"debuginfo</i>.</li>"
msgstr ""
"<li><b>Debug informatie</b>: toon pakkettendepots waarvan het id eindigt op "
"<i>-debuginfo</i>.</li>"

#: dnfdragora/helpinfo.py:107
msgid ""
"<li><b>Source</b>: show repositories whose id ends with <i>-source</i>.</li>"
msgstr ""
"<li><b>Bron</b>: toon pakkettendepots waarvan het id eindigt op <i>-bron</i>."
"</li>"

#: dnfdragora/helpinfo.py:108
msgid ""
"<li><b>Testing</b>: show repositories whose id contains <i>testing</i>.</li>"
msgstr ""
"<li><b>Testing</b>: toon pakkettendepots waarvan het id bevat <i>testing</i>."
"</li>"

#: dnfdragora/helpinfo.py:109 dnfdragora/helpinfo.py:283
#: dnfdragora/helpinfo.py:291 dnfdragora/helpinfo.py:298
#: dnfdragora/helpinfo.py:308
msgid "</ul>"
msgstr "</ul>"

#: dnfdragora/helpinfo.py:110
msgid ""
"If any repository of those types is currently <b>enabled</b> in DNF, the "
"corresponding checkbox is automatically turned on and the frame is expanded, "
"ensuring an active repository is never hidden.<br>"
msgstr ""
"Als een van deze pakketdepots momenteel is <b>ingeschakeld</b> in DNF, wordt "
"het bijhorende selectievakje automatisch aangevinkt, en vouwt het kader uit, "
"zodat een actief pakketdepot nooit verborgen blijft.<br>"

#: dnfdragora/helpinfo.py:111
msgid ""
"The filter selections are saved in the user configuration file and restored "
"at the next launch.<br>"
msgstr ""
"De filterselecties worden opgeslagen in het gebruikers-configuratiebestand. "
"Bij  de volgende keer opstarten worden zij hersteld.<br>"

#: dnfdragora/helpinfo.py:112
msgid "<h2>Quit</h2>"
msgstr "<h2>Afsluiten</h2>"

#: dnfdragora/helpinfo.py:113
msgid "This menu exits from dnfdragora.<br>"
msgstr "Dit menu-item zal dnfdragora afsluiten.<br>"

#: dnfdragora/helpinfo.py:120
msgid "Information Menu"
msgstr "Informatiemenu"

#: dnfdragora/helpinfo.py:122
msgid "<h2>History</h2>"
msgstr "<h2>Geschiedenis</h2>"

#: dnfdragora/helpinfo.py:123
#, python-format
msgid ""
"This menu opens the %s, which shows packages recently changed on the system."
msgstr ""
"Dit menu opent de %s, dit toont pakketten die onlangs in het systeem zijn "
"gewijzigd."

#: dnfdragora/helpinfo.py:124
msgid "<h2>System upgrade</h2>"
msgstr "<h2>Systeem opwaardering</h2>"

#: dnfdragora/helpinfo.py:125
#, python-format
msgid ""
"This menu opens the %s to prepare an offline distro upgrade to a target "
"releasever. "
msgstr ""
"Dit menu opent de %s om een ​​offline distributie-upgrade naar een doelrelease-"
"versie voor te bereiden. "

#: dnfdragora/helpinfo.py:126
msgid ""
"<b>Important:</b> the menu entry is shown only when systemd is available, "
"because execution is scheduled offline for reboot."
msgstr ""
"<b>Belangrijk:</b> de menuoptie wordt alleen weergegeven als systemd "
"beschikbaar is, omdat de uitvoering offline is gepland voor het opnieuw "
"starten."

#: dnfdragora/helpinfo.py:127
msgid "<h2>Advisory information</h2>"
msgstr "<h2>Informatie veiligheidsadvies</h2>"

#: dnfdragora/helpinfo.py:128
#, python-format
msgid ""
"This menu opens the %s to query advisory metadata (security, bugfix, "
"enhancement) with filters and inspect selected advisory details."
msgstr ""
"Dit menu opent de %s om adviesmetadata (beveiliging, bugfixes, "
"verbeteringen) op te vragen via filters, en geselecteerde beveiligingsadvies-"
"details te bekijken."

#: dnfdragora/helpinfo.py:135
msgid "Option Menu"
msgstr "Optiemenu"

#: dnfdragora/helpinfo.py:137
msgid "<h2>User preferences</h2>"
msgstr "<h2>Gebruikersinstellingen</h2>"

#: dnfdragora/helpinfo.py:138
#, python-format
msgid ""
"This menu opens a %s containing user settings to customize dnfdragora "
"behavior.<br>"
msgstr ""
"Dit menu-item opent een %s met gebruikersinstellingen om het gedrag van "
"dnfdragora aan te passen.<br>"

#: dnfdragora/helpinfo.py:138
msgid "dialog"
msgstr "dialoogvenster"

#: dnfdragora/helpinfo.py:146
msgid ""
"This dialog allows to customize dnfdragora behavior by changing options. "
"Some changes are available after closing the dialog, others need a "
"dnfdragora restart.<br><br>"
msgstr ""
"In dit dialoogvenster kunt u het gedrag van dnfdragora instellen. Sommige "
"instellingen zijn gelijk actief na het sluiten van het dialoogvenster, "
"andere vereisen een herstart van dnfdragora.<br><br>"

#: dnfdragora/helpinfo.py:147
msgid "<h2>System options</h2>"
msgstr "<h2>Systeemopties</h2>"

#: dnfdragora/helpinfo.py:148
msgid ""
"<ul><li><b>Run transactions on packages automatically without confirmation "
"needed</b>: if checked transactions do not need to be confirmed, dnfdragora "
"works as answering always <i>yes</i>."
msgstr ""
"<ul><li><b>Verwerk transacties op pakketten automatisch zonder om "
"bevestiging te vragen</b>: wanneer ingeschakeld hoeven transacties niet "
"bevestigd te worden, dnfdragora zal op alle vragen <i>ja</i>antwoorden."

#: dnfdragora/helpinfo.py:149
msgid ""
"<br><b>NOTE</b> that this option means that also removing packages is "
"silently accepted</li>"
msgstr ""
"<br><b>Let op</b> dat deze instelling ook inhoudt dat het verwijderen van "
"pakketten stil doorgevoerd wordt</li>"

#: dnfdragora/helpinfo.py:150
msgid ""
"<li><b>Force distsync as upgrade</b>: if enabled, queued upgrade actions are "
"resolved as distsync actions.</li>"
msgstr ""
"<li><b>Distsync forceren als upgrade</b>:Indien ingeschakeld, worden in de "
"wachtrij geplaatste upgradeacties afgehandeld als distsync-acties.</li>"

#: dnfdragora/helpinfo.py:151
msgid ""
"<li><b>Remove installed package to resolve transactions</b>: if enabled, "
"dependency solving can remove installed packages (<i>allow_erasing</i>).</li>"
msgstr ""
"<li><b>Verwijder het geïnstalleerde pakket om transacties op te lossen.</b>:"
"Indien ingeschakeld, kan het oplossen van afhankelijkheden geïnstalleerde "
"pakketten verwijderen.(<i>wissen toestaan</i>).</li>"

#: dnfdragora/helpinfo.py:152
msgid ""
"<li><b>Metadata expire time</b>: time to force Metadata expiration, the "
"value is expressed in hours</li></ul>"
msgstr ""
"<li><b>Verlooptijd voor metadata</b>: tijd om metadata te laten verlopen, de "
"waarde wordt uitgedrukt in uren</li></ul>"

#: dnfdragora/helpinfo.py:153
msgid "<h2>dnfdragora-updater options</h2>"
msgstr "<h2>dnfdragora-bijwerker-opties</h2>"

#: dnfdragora/helpinfo.py:154
msgid ""
"<ul><li><b>Hide dnfdragora-update menu if there are no updates</b>: if "
"checked dnfdragora-update is hidden when no updates are available."
msgstr ""
"<ul><li><b>Verberg het dnfdragora-update menu als er geen updates zijn.</b>: "
"indien aangevinkt, blijft dnfdragora-bijwerker onzichtbaar wanneer er geen "
"updates beschikbaar zijn."

#: dnfdragora/helpinfo.py:155
msgid ""
"<br><b>NOTE</b> that this option is experimental, not all desktops manage it "
"as expected</li>"
msgstr ""
"<br><b>NOTE:</b> deze optie is experimenteel en werkt niet op alle desktops "
"zoals verwacht.</li>"

#: dnfdragora/helpinfo.py:156
msgid ""
"<li><b>Interval to check for updates</b>: how often dnfdragora-update checks "
"for updates; value is expressed in minutes (10..10080).</li></ul>"
msgstr ""
"<li><b>Interval om te controleren op updates</b>:Hoe vaak dnfdragora-update "
"controleert op updates; de waarde is in minuten (10..10080).</li></ul>"

#: dnfdragora/helpinfo.py:157
msgid "<h2>Layout options</h2>"
msgstr "<h2>Indelingsopties</h2>"

#: dnfdragora/helpinfo.py:158
msgid ""
"<ul><li><b>Show updates</b>: if checked dnfdragora starts with <i>updates</"
"i> filter active, i.e. showing only package available for updates if any.</"
"li>"
msgstr ""
"<ul><li><b>Toon herzieningen</b>: wanneer ingeschakeld zal dnfdragora "
"starten met het <i>herzieningen</i> filter actief, oftewel enkel pakketten "
"voor herzieningen worden weergegeven indien er herzieningen zijn.</li>"

#: dnfdragora/helpinfo.py:159
msgid ""
"<li><b>Do not show groups view</b>: filtering by groups could require CPU if "
"using comps, if this option is checked dnfdragora starts showing all "
"packages.</li></ul>"
msgstr ""
"<li><b>Toon de groepsweergave niet</b>: filteren op groepen per groep kan "
"veel van de CPU vragen. Wanneer deze optie is ingeschakeld zal dnfdragora na "
"het starten alle pakketten tonen.</li></ul>"

#: dnfdragora/helpinfo.py:160
msgid "<b>NOTE</b> that the above options require dnfdragora to be restarted."
msgstr ""
"<b>Opmerking</b>: de bovenstaande opties zijn pas actief nadat dnfdragora "
"herstart is."

#: dnfdragora/helpinfo.py:161
msgid "<h2>Logging options</h2>"
msgstr "<h2>Logboek-opties</h2>"

#: dnfdragora/helpinfo.py:162
msgid ""
"Enable these options to let dnfdragora log on file called <i>dnfdragora.log</"
"i>."
msgstr ""
"Met deze opties ingeschakeld zal dnfdragora een logboek wegschrijven naar "
"het bestand <i>dnfdragora.log</i>."

#: dnfdragora/helpinfo.py:163
msgid ""
"<ul><li><b>Change directory</b>: this option allows you to set the logging "
"directory; the directory must exist and needs write permission.</li>"
msgstr ""
"<ul><li><b>Map wijzigen</b>: met deze optie stelt u de map voor het logboek "
"in. De map moet wel bestaan en vereist  schrijfrechten.</li>"

#: dnfdragora/helpinfo.py:164
msgid ""
"<li><b>Debug level</b>: if checked, verbose logging is enabled.</li></ul>"
msgstr ""
"<li><b>Foutopsporingsniveau</b>: indien aangevinkt worden uitgebreide logs "
"bijgehouden.</li></ul>"

#: dnfdragora/helpinfo.py:172
msgid "Help Menu"
msgstr "Hulpmenu"

#: dnfdragora/helpinfo.py:174
msgid "<h2>Manual</h2>"
msgstr "<h2>Handleiding</h2>"

#: dnfdragora/helpinfo.py:175
msgid "This menu opens dnfdragora help dialog."
msgstr "Dit menu-item opent de hulpdialoog van dnfdragora."

#: dnfdragora/helpinfo.py:176
msgid "<h2>About</h2>"
msgstr "<h2>Over</h2>"

#: dnfdragora/helpinfo.py:177
msgid "This menu opens dnfdragora about dialog."
msgstr "Dit menu-item opent de over-dialoog van dnfdragora."

#: dnfdragora/helpinfo.py:187
msgid "<h2>Views</h2>"
msgstr "<h2>Weergaves</h2>"

#: dnfdragora/helpinfo.py:188
msgid ""
"The first combobox allows you to show packages by groups. If <i>Groups</i> "
"is selected, the group panel shows a tree view containing groups, and "
"selecting a group shows related packages in the package panel.<br>"
msgstr ""
"Met de eerste keuzelijst kunt u pakketten per groep weergeven. Als "
"<i>Groups</i> is geselecteerd, toont het groepspaneel een boomstructuur met "
"groepen. Het selecteren van een groep toont de bijbehorende pakketten in het "
"pakketpaneel.<br>"

#: dnfdragora/helpinfo.py:189
msgid ""
"If <i>All</i> is selected, the package panel contains all the packages.<br>"
msgstr "Kiest u <i>All</i> dan toont het pakkettenpaneel alle pakketten.<br>"

#: dnfdragora/helpinfo.py:190 dnfdragora/helpinfo.py:277
#: dnfdragora/helpinfo.py:361
msgid "<h2>Filters</h2>"
msgstr "<h2>Filters</h2>"

#: dnfdragora/helpinfo.py:191
msgid ""
"The Filter combobox allows you to filter the packages shown in the package "
"panel by:"
msgstr ""
"In de Filter-combobox kunt u de getoonde pakketten in het pakkettenpaneel "
"filteren op:"

#: dnfdragora/helpinfo.py:193
msgid "<li><b>Installed</b>: shows installed packages only.</li>"
msgstr "<li><b>Geïnstalleerd</b>: Toont enkel geïnstalleerde pakketten.</li>"

#: dnfdragora/helpinfo.py:194
msgid "<li><b>Not installed</b>: shows available packages only.</li>"
msgstr "<li><b>Niet-geïnstalleerd</b>: Toont enkel beschikbare pakketten.</li>"

#: dnfdragora/helpinfo.py:195
msgid ""
"<li><b>To update</b>: shows packages that are available for updates only.</"
"li>"
msgstr ""
"<li><b>Moet bijgewerkt worden</b>: toont enkel pakketten waar herzieningen "
"voor beschikbaar zijn.</li>"

#: dnfdragora/helpinfo.py:196
msgid ""
"<li><b>Desktop Applications</b>: shows packages that provide desktop/GUI "
"applications.</li>"
msgstr ""
"<li><b>Desktop Programma's</b>: toont pakketten die desktop-/GUI-programma's "
"leveren."

#: dnfdragora/helpinfo.py:197
msgid ""
"<li><b>Show x86_64 and noarch only</b>: if dnfdragora is running on x86_64 "
"architecture, it hides i686 packages.</li>"
msgstr ""
"<li><b>Toon alleen x86_64 en noarch</b>: als dnfdragora draait op de x86_64 "
"architectuur worden i686-pakketten verborgen.</li>"

#: dnfdragora/helpinfo.py:198
msgid ""
"<li><b>All</b>: shows all the packages, i.e. available, updates and "
"installed.</li>"
msgstr ""
"<li><b>Alle</b>: toont alle pakketten, oftewel beschikbaar, herzieningen en "
"geïnstalleerd.</li></ul>"

#: dnfdragora/helpinfo.py:200
msgid "<h2>Search</h2>"
msgstr "<h2>Zoeken</h2>"

#: dnfdragora/helpinfo.py:201
#, python-format
msgid "Pressing the <b>Search</b> button (magnifier icon) opens the %s "
msgstr "Het aanklikken van de <b>Zoek</b> knop (vergrootglas) opent de %s "

#: dnfdragora/helpinfo.py:202
msgid ""
"that provides full-featured package search. When a search is active the "
"filter combobox is disabled "
msgstr ""
"wat een uitgebreide pakketzoekfunctie biedt. Wanneer een zoekopdracht actief "
"is, is het filterkeuzemenu uitgeschakeld."

#: dnfdragora/helpinfo.py:203
msgid "and an info label shows the active search text or dependency query. "
msgstr "en een infolabel toont de actieve zoektekst of afhankelijkheidsvraag. "

#: dnfdragora/helpinfo.py:204
msgid ""
"The <b>Clear search</b> button (eraser icon) next to the Search button "
"resets all search state "
msgstr ""
"De knop <b>Zoekopdracht wissen</b> (gummmetje)  naast de Zoek-knop reset  "
"alle zoek-status "

#: dnfdragora/helpinfo.py:205
msgid "and re-enables the filter combobox.<br>"
msgstr "en schakelt de filterkeuzelijst opnieuw in.<br>"

#: dnfdragora/helpinfo.py:215
msgid ""
"This panel shows all the groups available to filter packages, if the Groups "
"view is selected. The special group <i>Search</i> is added after a search is "
"performed."
msgstr ""
"Dit paneel toont alle groepen om te filteren, wanneer Groepsweergave "
"geselecteerd is. Speciale groep <i>Zoekresultaten</i> wordt toegevoegd nadat "
"een zoekopdracht is uitgevoerd."

#: dnfdragora/helpinfo.py:225
msgid ""
"This panel shows all the filtered packages with their basic information such "
"as <i>name</i>, <i>summary</i>, <i>version</i>, <i>release</i>, "
"<i>architecture</i>, <i>size</i>, and <i>status</i>."
msgstr ""
"Dit paneel toont alle gefilterde pakketten met belangrijke informatie zoals "
"<i>naam</i>, <i>samenvatting</i>, <i>versie</i>, <i>uitgave</i>, "
"<i>architectuur</i>, <i>grootte</i> en <i>status</i>."

#: dnfdragora/helpinfo.py:226
msgid ""
"A checkbox for any packages is available to add related package to "
"transaction for installing, updating or removing."
msgstr ""
"Een aanvinkvakje voor ieder pakket is aanwezig om om gerelateerde pakketten "
"toe te voegen aan de transactie voor installeren, bijwerken of verwijderen."

#: dnfdragora/helpinfo.py:236
msgid ""
"This panel shows all the package information such as <i>description</i>, "
"<i>URL</i>, <i>repository</i>, <i>requirements</i>, <i>file list</i>, and "
"<i>changelog</i>."
msgstr ""
"Dit paneel toont alle informatie van een pakket, zoals <i>omschrijving</i>, "
"<i>URL</i>, <i>pakkettendepot</i>, <i>vereisten</i>, <i>bestandslijst</i> en "
"<i>wijzigingslogboek</i>."

#: dnfdragora/helpinfo.py:237
msgid ""
"<br><br><i>Note that changelog is not provided by dnfdaemon at the moment.</"
"i>"
msgstr ""
"<br><br><i>Opmerking: het wijzigingslogboek is momenteel niet beschikbaar "
"vanuit dnfdaemon.</i>"

#: dnfdragora/helpinfo.py:245
msgid "Progress bar"
msgstr "Voortgangsbalk"

#: dnfdragora/helpinfo.py:247
msgid ""
"Progress bar shows dnfdragora operations progression such as transactions "
"and caching data."
msgstr ""
"Voortgangsbalk die de voortgang toont van handelingen van dnfdragora zoals "
"transacties en de cache bijwerken van gegevens."

#: dnfdragora/helpinfo.py:255
msgid "Buttons line"
msgstr "Knoplijn"

#: dnfdragora/helpinfo.py:257
msgid ""
"<ul><li><b>Apply</b>: when some packages are selected for installing or "
"updating or deselected for uninstalling this button runs the transaction to "
"be performed.</li>"
msgstr ""
"<ul><li><b>Toepassen</b>: wanneer er pakketten zijn geselecteerd voor "
"installeren of bijwerken of zijn ge-deselecteerd voor verwijderen zal deze "
"knop de transactie starten en uitvoeren.</li>"

#: dnfdragora/helpinfo.py:258
msgid ""
"<li><b>Select all</b>: if packages are filtered for updates only this button "
"allows to select all the packages in one shot.</li>"
msgstr ""
"<li><b>Selecteer allen</b>: wanneer pakketten zijn gefilterd op herzieningen "
"kan alleen deze knop gebruikt worden om alle pakketten in één keer te "
"selecteren.</li>"

#: dnfdragora/helpinfo.py:259
msgid "<li><b>Quit</b>: exits from dnfdragora.</li></ul>"
msgstr "<li><b>Afsluiten</b>: sluit dnfdragora af.</li></ul>"

#: dnfdragora/helpinfo.py:260
msgid "<h2>Offline transaction confirmation</h2>"
msgstr "<h2>Offline transactiebevestiging</h2>"

#: dnfdragora/helpinfo.py:261
msgid ""
"When transaction confirmation is shown, you can enable <b>Offline</b> and "
"choose <b>Reboot</b> or <b>Power off</b>. "
msgstr ""
"Wanneer de transactiebevestiging wordt getoond, kunt u <b>Offline</b> "
"inschakelen en kiezen: <b>Herstart pc</b> of <b>pc uitschakelen</b>. "

#: dnfdragora/helpinfo.py:262
msgid ""
"dnfdragora schedules the offline transaction and shows a reminder to reboot "
"or power off to continue at the next startup. "
msgstr ""
"dnfdragora agendeert de offline transactie in en geeft een herinnering weer "
"om de computer opnieuw op te starten of uit te schakelen om verder te gaan "
"bij de volgende opstart."

#: dnfdragora/helpinfo.py:263
msgid ""
"While offline scheduling is in progress, cancellation is disabled and the "
"progress window stays open until scheduling is completed."
msgstr ""
"Tijdens het offline agenderen is annuleren niet mogelijk en blijft het "
"voortgangsvenster open totdat het inplannen is voltooid."

#: dnfdragora/helpinfo.py:273
msgid ""
"The History dialog shows packages that have been recently changed on the "
"system by querying the dnf5daemon History API.<br><br>"
msgstr ""
"Het Historie-dialoogvenster toont pakketten die onlangs in het systeem zijn "
"gewijzigd, door te zoeken in de dnf5daemon History API.<br><br>"

#: dnfdragora/helpinfo.py:274 dnfdragora/helpinfo.py:325
#: dnfdragora/helpinfo.py:340 dnfdragora/helpinfo.py:359
msgid "<h2>Opening the dialog</h2>"
msgstr "<h2>Het dialoog-venster wordt geopend</h2>"

#: dnfdragora/helpinfo.py:275
msgid "Open the dialog from the menu bar: <b>Actions → History</b>.<br>"
msgstr ""
"Open het dialoogvenster vanuit de menu-balk: <b>Acties → Geschiedenis</b>."
"<br>"

#: dnfdragora/helpinfo.py:276 dnfdragora/helpinfo.py:327
msgid ""
"The main dnfdragora window is disabled while the dialog is open to prevent "
"unintended interactions.<br><br>"
msgstr ""
"Het hoofd-dnfdragora venster is uitgeschakeld zolang het dialoogvenster open "
"staat, om onbedoelde interacties te voorkomen.<br><br>"

#: dnfdragora/helpinfo.py:278
msgid ""
"The <b>Filters</b> section at the top of the dialog lets you narrow the "
"results:<br>"
msgstr ""
"In het gedeelte <b>Filters</b> bovenaan het dialoogvenster kunt u de "
"resultaten verfijnen:<br>"

#: dnfdragora/helpinfo.py:280
msgid ""
"<li><b>Since (YYYY-MM-DD)</b>: enter a date to show only packages changed on "
"or after that date. "
msgstr ""
"<li><b>Sinds (JJJJ-MM-DD)</b>: voer een datum in om alleen pakketten weer te "
"geven die op of na die datum zijn gewijzigd. "

#: dnfdragora/helpinfo.py:281
msgid "Leave empty to retrieve all available history. "
msgstr "Laat dit veld leeg om alle beschikbare geschiedenis op te halen."

#: dnfdragora/helpinfo.py:282
msgid ""
"The date is converted to a Unix timestamp before being sent to the daemon.</"
"li>"
msgstr ""
"De datum wordt omgezet naar een Unix-tijdstempel voordat deze naar de daemon "
"wordt verzonden.</li>"

#: dnfdragora/helpinfo.py:284
msgid "<h2>Change type checkboxes</h2>"
msgstr "<h2>Selectievakjes voor het wijzigen van het type</h2>"

#: dnfdragora/helpinfo.py:285
msgid ""
"Four checkboxes let you choose which kinds of package changes to include in "
"the results:<br>"
msgstr ""
"Met vier selectievakjes kiest u welke soorten pakketwijzigingen u wilt zien:"
"<br>"

#: dnfdragora/helpinfo.py:287
msgid "<li><b>Installed</b>: packages that were newly installed.</li>"
msgstr ""
"<li><b>Geïnstalleerd</b>: pakketten die onlangs werden geïnstalleerd.</li>"

#: dnfdragora/helpinfo.py:288
msgid "<li><b>Removed</b>: packages that were removed from the system.</li>"
msgstr "<li><b>Verwijderd</b>: pakketten die uit uw systeem werden verwijderd."

#: dnfdragora/helpinfo.py:289
msgid ""
"<li><b>Upgraded</b>: packages that were upgraded to a newer version.</li>"
msgstr ""
"<li><b>Opgewaardeerd</b>: pakketten die zijn opgewaardeerd naar een nieuwere "
"versie.</li>"

#: dnfdragora/helpinfo.py:290
msgid ""
"<li><b>Downgraded</b>: packages that were downgraded to an older version.</"
"li>"
msgstr ""
"<li><b>Gedowngraded</b>: pakketten die werden gedowngraded naar een oudere "
"versie.</li>"

#: dnfdragora/helpinfo.py:292
msgid ""
"Uncheck any type you are not interested in to reduce the number of rows "
"shown.<br><br>"
msgstr ""
"Schakel een 'Type' uit waarin u niet geïnteresseerd bent, om het aantal "
"getoonde rijen te verminderen..<br><br>"

#: dnfdragora/helpinfo.py:293
msgid "<h2>Advisory options</h2>"
msgstr "<h2>Opties voor beveiligingsadviezen</h2>"

#: dnfdragora/helpinfo.py:295
msgid ""
"<li><b>Include advisories</b>: when checked, advisory information (security, "
"bugfix, enhancement) is included where available.</li>"
msgstr ""
"<li><b>Inclusief adviezen</b>: indien aangevinkt, ziet u informatie over "
"adviezen (beveiliging, bugfixes, verbeteringen) indien beschikbaar.</li>"

#: dnfdragora/helpinfo.py:296
msgid ""
"<li><b>All advisories</b>: when checked together with <i>Include advisories</"
"i>, all advisory types are returned rather than only the most relevant one "
"per package. "
msgstr ""
"<li><b>Alle adviezen</b>: indien aangevinkt samen met <i>Inclusief adviezen</"
"i>, ziet u alle soorten adviezen, in plaats van alleen het meest relevante "
"advies per pakket. "

#: dnfdragora/helpinfo.py:297
msgid ""
"This option is automatically disabled when <i>Include advisories</i> is "
"unchecked.</li>"
msgstr ""
"Deze optie is automatisch uitgeschakeld wanneer <i>Inclusief adviezen</i> "
"niet is aangevinkt.</li>"

#: dnfdragora/helpinfo.py:299 dnfdragora/helpinfo.py:363
msgid "<h2>Results table</h2>"
msgstr "<h2>Resultaten-tabel</h2>"

#: dnfdragora/helpinfo.py:300
msgid ""
"The table shows one row per changed package with the following columns:<br>"
msgstr ""
"De tabel toont één rij per gewijzigd pakket met de volgende kolommen:<br>"

#: dnfdragora/helpinfo.py:302
msgid "<li><b>Name</b>: the package name.</li>"
msgstr "<li><b>Naam</b>: de naam van het pakket.</li>"

#: dnfdragora/helpinfo.py:303
msgid ""
"<li><b>EVR</b>: epoch:version-release of the new (installed) version.</li>"
msgstr ""
"<li><b>EVR</b>: epoch:versie-release van de nieuwe (geïnstalleerde) versie.</"
"li>"

#: dnfdragora/helpinfo.py:304
msgid "<li><b>Arch</b>: the package architecture.</li>"
msgstr "<li><b>Arch</b>: de pakket-architectuur.</li>"

#: dnfdragora/helpinfo.py:305
msgid ""
"<li><b>Action</b>: one of <i>installed</i>, <i>removed</i>, <i>upgraded</i>, "
"or <i>downgraded</i>.</li>"
msgstr ""
"<li><b>Actie</b>: één van deze <i>geïnstalleerd</i>, <i>verwijderd</i>, "
"<i>opgewaardeerd</i>, of <i>gedowngraded</i>.</li>"

#: dnfdragora/helpinfo.py:306
msgid ""
"<li><b>Date</b>: the date and time of the transaction (YYYY-MM-DD HH:MM).</"
"li>"
msgstr ""
"<li><b>Datum</b>: de datum en tijd van de transactie (JJJJ-MM-DD HH:MM).</li>"

#: dnfdragora/helpinfo.py:307
msgid "<li><b>Summary</b>: a short description of the package.</li>"
msgstr "<li><b>Samenvatting</b>: korte omschrijving van het pakket.</li>"

#: dnfdragora/helpinfo.py:309
msgid ""
"If no packages match the current filters a <i>No results</i> row is shown."
"<br>"
msgstr ""
"Als geen enkel pakket overeenkomt met de huidige filters, ziet u een <i>No "
"results</i> rij.<br>"

#: dnfdragora/helpinfo.py:310
msgid ""
"If the daemon call fails the error message is displayed in the table so you "
"can diagnose the problem.<br><br>"
msgstr ""
"Als de daemon-aanroep mislukt, ziet u het fout-bericht in the tabel, zodat u "
"het probleem kunt onderzoeken.<br><br>"

#: dnfdragora/helpinfo.py:311
msgid "<h2>Refresh button</h2>"
msgstr "<h2>Vernieuwen-knop</h2>"

#: dnfdragora/helpinfo.py:312
msgid ""
"Press <b>Refresh</b> to re-query the daemon with the current filter "
"settings. "
msgstr ""
"Druk op <b>Vernieuwen</b> om de daemon opnieuw te bevragen met de huidige "
"filter-instellingen. "

#: dnfdragora/helpinfo.py:313
msgid "The dialog also queries automatically when it first opens.<br><br>"
msgstr ""
"Het dialoog-venster voert ook automatisch een onderzoek uit wanneer het voor "
"het eerst wordt geopend.<br><br>"

#: dnfdragora/helpinfo.py:314
msgid "<h2>Close button</h2>"
msgstr "<h2>Sluit-knop</h2>"

#: dnfdragora/helpinfo.py:315
msgid ""
"Press <b>Close</b> (or the window close button) to dismiss the dialog and "
"return to the main window.<br>"
msgstr ""
"Druk op <b>Sluiten</b> (of het venster-sluitknopje) om het dialoogvenster te "
"sluiten, en terug te keren naar het hoofdvenster.<br>"

#: dnfdragora/helpinfo.py:324
msgid ""
"The Offline transactions dialog shows the current offline transaction status "
"reported by dnf5daemon.<br><br>"
msgstr ""
"Het dialoogvenster 'Offline transacties' toont de huidige status van offline "
"transacties zoals gerapporteerd door dnf5daemon.<br><br>"

#: dnfdragora/helpinfo.py:326
msgid ""
"Open the dialog from the menu bar: <b>Actions → Offline transactions</b>.<br>"
msgstr ""
"Open het dialoogvenster via de menubalk:<b>Acties → Offline transacties</b>."
"<br>"

#: dnfdragora/helpinfo.py:328
msgid "<h2>Status and actions</h2>"
msgstr "<h2>Status en acties</h2>"

#: dnfdragora/helpinfo.py:329
msgid ""
"Press <b>Refresh</b> to reload the current offline status. If an offline "
"transaction is pending, you can choose <b>Reboot</b> or <b>Power off</b> and "
"press <b>Finalize</b> to set the finish action, or press <b>Clean</b> to "
"remove the scheduled offline transaction data.<br>"
msgstr ""
"Druk op <b>Ververs</b> om de huidige offline-status te herladen. Als er een "
"offline transactie in behandeling is, kunt u kiezen voor<b>Herstart pc</b> "
"of <b>Pc uitschakelen</b> en druk op <b>Beëindigen</b> om de "
"beëindigingsactie in te stellen, of druk op <b>Opruimen</b> om de "
"geagendeerde offline transactiegegevens te verwijderen.<br>"

#: dnfdragora/helpinfo.py:339
msgid ""
"The System upgrade dialog prepares a distribution upgrade transaction for "
"offline execution at reboot using dnf5daemon.<br><br>"
msgstr ""
"Het dialoogvenster voor systeemupgrades bereidt een distributie-upgrade "
"voor, voor offline uitvoering tijdens het opnieuw opstarten van de pc met "
"behulp van dnf5daemon.<br><br>"

#: dnfdragora/helpinfo.py:341
msgid "Open the dialog from the menu bar: <b>Actions → System upgrade</b>.<br>"
msgstr ""
"Open het dialoogvenster vanuit de menubalk: <b>Actions → Systeem "
"opwaardering</b>.<br>"

#: dnfdragora/helpinfo.py:342
msgid ""
"<b>Note:</b> this menu is available only on systems where systemd is running."
"<br><br>"
msgstr ""
"<b>Opmerking:</b> dit menu is alleen aanwezig op systemen waarop systemd "
"draait.<br><br>"

#: dnfdragora/helpinfo.py:343
msgid "<h2>Safety and confirmation</h2>"
msgstr "<h2>Veiligheid en bevestiging</h2>"

#: dnfdragora/helpinfo.py:344
msgid ""
"The dialog starts with a warning and keeps advanced options hidden by "
"default. "
msgstr ""
"Het dialoogvenster begint met een waarschuwing en houdt geavanceerde opties "
"standaard verborgen. "

#: dnfdragora/helpinfo.py:345
msgid ""
"Enable the acknowledgement checkbox to open the options frame and proceed "
"only if you fully understand the risks.<br><br>"
msgstr ""
"Schakel het selectievakje voor bevestiging in om het optievenster te openen "
"en ga alleen verder als u de risico's volledig begrijpt.<br><br>"

#: dnfdragora/helpinfo.py:346
msgid "<h2>Releasever option</h2>"
msgstr "<h2>Releaseversie-optie</h2>"

#: dnfdragora/helpinfo.py:347
msgid ""
"Enter the target <i>releasever</i> exactly as expected by repositories "
"metadata (for example development values such as <i>cauldron</i> or "
"<i>rawhide</i>, where applicable).<br><br>"
msgstr ""
"Typ de doel <i>releaseversie</i> exact in zoals verwacht door de metadata "
"van de pakketdepots (bijvoorbeeld ontwikkelingswaarden als  <i>cauldron</i> "
"of <i>rawhide</i>, indien van toepassing).<br><br>"

#: dnfdragora/helpinfo.py:348
msgid "<h2>Execution flow</h2>"
msgstr "<h2>Uitvoeringsstroom</h2>"

#: dnfdragora/helpinfo.py:349
msgid ""
"After confirmation, dnfdragora reopens the daemon session with the chosen "
"releasever, prepares system-upgrade in <i>distrosync</i> mode with "
"interactive prompts enabled, resolves dependencies with allow-erasing, then "
"schedules the transaction offline and sets reboot as finish action.<br>"
msgstr ""
"Na bevestiging heropent dnfdragora de daemon-sessie met de gekozen releaser, "
"bereidt de systeemupgrade voor in  <i>distrosync</i> modus met interactieve "
"prompts ingeschakeld, lost afhankelijkheden op met allow-erasing, plant "
"vervolgens de transactie offline in en stelt herstarten in als afsluitende "
"actie. <br>"

#: dnfdragora/helpinfo.py:358
msgid ""
"The Advisory information dialog queries dnf5daemon advisory metadata and "
"shows matching advisories in a table.<br><br>"
msgstr ""
"Het dialoogvenster met informatie over het beveiligingsadvies raadpleegt de "
"metagegevens van dnf5daemon voor adviezen en toont overeenkomende "
"beveiligingsadviezen in een tabel.<br><br>"

#: dnfdragora/helpinfo.py:360
msgid ""
"Open the dialog from the menu bar: <b>Actions → Advisory information</b>."
"<br><br>"
msgstr ""
"Open het dialoogvenster vanuit de menubalk: <b>Actions → Informatie "
"beveiligingsadvies</b>.<br>"

#: dnfdragora/helpinfo.py:362
msgid ""
"Use the filter area to narrow results by availability, advisory IDs, package "
"name patterns, Bugzilla IDs, CVE IDs, advisory types, severities, and "
"toggles for advisories containing CVE/Bugzilla references.<br><br>"
msgstr ""
"Gebruik het filtergebied om de resultaten te verfijnen op beschikbaarheid, "
"advies-ID's, pakketnaampatronen, Bugzilla-ID's, CVE-ID's, adviestypen, "
"ernstniveaus, en schakel de optie in of uit voor adviezen die CVE/Bugzilla-"
"verwijzingen bevatten."

#: dnfdragora/helpinfo.py:364
msgid ""
"The main table shows <b>Advisory ID</b>, <b>Type</b>, <b>Severity</b>, and "
"<b>Title</b> for each advisory returned by the daemon.<br><br>"
msgstr ""
"The hoofdtabel toont <b>Beveiligingsadvies-ID</b>, <b>Type</b>, <b>Ernst</"
"b>, en <b>Titel</b> voor elk beveiligingsadvies dat de deamon heeft geopperd."

#: dnfdragora/helpinfo.py:365
msgid "<h2>Selected advisory details</h2>"
msgstr "<h2>Gekozen details beveiligingsadvies</h2>"

#: dnfdragora/helpinfo.py:366
msgid ""
"Selecting a row updates the details table with available fields such as "
"vendor, status, description, message, collections, and references.<br><br>"
msgstr ""
"Door een rij te selecteren, wordt de detailtabel bijgewerkt met beschikbare "
"velden zoals fabrikant, status, beschrijving, bericht, collecties en "
"referenties."

#: dnfdragora/helpinfo.py:367
msgid "<h2>Refresh and Close</h2>"
msgstr "<h2>Vernieuwen en Sluiten</h2>"

#: dnfdragora/helpinfo.py:368
msgid ""
"Press <b>Refresh</b> to run the query with current filters, or <b>Close</b> "
"to dismiss the dialog and return to the main window.<br>"
msgstr ""
"Typ <b>Ververs</b> om het onderzoek uit te voeren met de huidige filters, of "
"<b>Sluiten</b> om het dialoogvenster te sluiten en terug te keren naar het "
"hoofdvenster.<br>"

#: dnfdragora/progress_ui.py:193
msgid "Transaction completed successfully"
msgstr "De transactie is geslaagd."

#: dnfdragora/progress_ui.py:194
msgid "Transaction completed with errors"
msgstr "Transactie uitgevoerd met waarschuwingen"

#: dnfdragora/progress_ui.py:197
msgid "Transaction completed"
msgstr "Transactie afgerond"

#: dnfdragora/progress_ui.py:210
msgid ""
"Offline transaction scheduled. Reboot or power off to continue on next "
"startup."
msgstr ""
"Offline transactie gepland. Herstart de computer of schakel de pc uit om "
"verder te gaan na de volgende opstart."

#: dnfdragora/progress_ui.py:212
msgid "Offline transaction scheduled"
msgstr "Offline transactie ingepland"

#: dnfdragora/progress_ui.py:247
