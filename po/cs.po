msgid "dnfdragora"
msgstr "dnfdragora"

#: share/metainfo/org.mageia.dnfdragora.metainfo.xml:9
msgid "ManaTools"
msgstr ""

#: share/metainfo/org.mageia.dnfdragora.metainfo.xml:11
msgid "A frontend for DNF using libyui UI abstraction library"
msgstr "Grafické rozhraní DNF používající abstraktní knihovnu rozhraní libyui"

#: share/metainfo/org.mageia.dnfdragora.metainfo.xml:13
msgid ""
"dnfdragora is a DNF frontend, inspired by rpmdragora from Mageia (originally "
"rpmdrake)."
msgstr ""
"dnfdragora je grafická nadstavba DNF, inspirována rpmdragora z distribuce "
"Mageia (původně rpmdrake)."

#: share/metainfo/org.mageia.dnfdragora.metainfo.xml:17
msgid ""
"dnfdragora is written in Python 3 and uses libYui, the widget abstraction "
"library written by SUSE, so that it can be run using Qt 5, GTK+ 3, or "
"ncurses interfaces. It provides a frontend for the DNF package manager that "
"can be used in any kind of system environment."
msgstr ""
"dnfdragora je napsána v Python 3 a používá libYui, abstraktní knihovnu pro "
"doplňky napsanou SUSE. Takže může být provozována pod Qt 5, GTK+ 3, nebo "
"ncurses rozhraními. Přináší grafické rozhraní pro správce balíčků DNF, který "
"může být použit v jakémkoliv systémovém prostředí. "

