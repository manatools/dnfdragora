msgid "dnfdragora"
msgstr "dnfdragora"

#: share/metainfo/org.mageia.dnfdragora.metainfo.xml:9
msgid "ManaTools"
msgstr ""

#: share/metainfo/org.mageia.dnfdragora.metainfo.xml:11
msgid "A frontend for DNF using libyui UI abstraction library"
msgstr ""
"En frontend til DNF som bruger libyui brugerflade-abstraktionsbibliotek"

#: share/metainfo/org.mageia.dnfdragora.metainfo.xml:13
msgid ""
"dnfdragora is a DNF frontend, inspired by rpmdragora from Mageia (originally "
"rpmdrake)."
msgstr ""
"dnfdragora er en DNF-frontend, inspireret af rpmdragora fra Mageia "
"(oprindeligt rpmdrake)."

#: share/metainfo/org.mageia.dnfdragora.metainfo.xml:17
msgid ""
"dnfdragora is written in Python 3 and uses manatools AUI, the widget "
"abstraction library written for manatools applications based on the libYUI "
"experience, so that it can be run using Qt 6 (pySide), GTK 4, or ncurses "
"interfaces. It provides a frontend for the DNF package manager, using DNF 5 "
"daemon, that can be used in any kind of system environment."
msgstr ""

