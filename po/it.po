#~ msgid ""
#~ "This menu opens a dialog that allows to enable or disable repositories. "
#~ "Any changes are valid for the time dnfdragora is running and it is not "
#~ "permanent.<br>"
#~ msgstr ""
#~ "Questo menù apre una finestra di dialog che permette di abilitare o "
#~ "disabilitare i repository. Tutti i cambiamenti sono validi per il tempo "
