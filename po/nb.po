msgid "supplement"
msgstr "tillegg"

#: dnfdragora/dialogs.py:2388
msgid "obsolete"
msgstr "udtatert"

#: dnfdragora/dialogs.py:2389
msgid "conflict with"
msgstr "i konflikt med"

#: dnfdragora/dialogs.py:2392
msgid "&Dependency query"
msgstr "&Avhengighetsspørring"

#: dnfdragora/dialogs.py:2394
msgid ""
"When checked, the Find field is used as a capability name and packages are "
"searched by dependency relation instead of text pattern."
msgstr ""
"Når det er avmerket, brukes Søk-feltet som et funksjonsnavn, og pakker søkes "
"etter avhengighetsrelasjon i stedet for tekstmønster."

#: dnfdragora/dialogs.py:2399
msgid "Find packages that:"
msgstr "Finnpakker som:"

#: dnfdragora/dialogs.py:2412
msgid ""
"Choose the dependency relation to search: provide, require, depend on, "
"recommend, etc."
msgstr ""
"Velg avhengighetsrelasjonen for søket: tilby, kreve, stole på, anbefale osv."

#: dnfdragora/dialogs.py:2413
msgid "the capability in \"Find\" field"
msgstr "muligheten i «Finn»-feltet"

#: dnfdragora/dialogs.py:2420
msgid "Limit to repositories"
msgstr "Begrens til arkiver"

#: dnfdragora/dialogs.py:2422
msgid "When checked, the search is restricted to the selected repositories."
msgstr "Når det er avkrysset, er søket begrenset til de valgte arkivene."

#: dnfdragora/dialogs.py:2445
msgid "Limit to architectures"
msgstr "Begrens til arkitekturer"

#: dnfdragora/dialogs.py:2447
msgid ""
"When checked, the search is restricted to the selected CPU architectures."
msgstr ""
"Når dette alternativet er avkrysset, er søket begrenset til de valgte CPU-"
"arkitekturene."

#: dnfdragora/dialogs.py:2472 dnfdragora/ui.py:686
msgid "&Search"
msgstr "&Søk"

#: dnfdragora/dialogs.py:2473
msgid "Run the search and show matching packages."
msgstr "Kjør søket og vis samsvarende pakker."

#: dnfdragora/dialogs.py:2475
msgid "&Clear"
msgstr "&Fjern"

#: dnfdragora/dialogs.py:2476
msgid "Clear the Find field and reset the dependency query frame."
