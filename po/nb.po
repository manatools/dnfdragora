#: dnfdragora/dialogs.py:1534
msgid "N&ames"
msgstr "N&avn"

#: dnfdragora/dialogs.py:1536
msgid "Search in package names and NEVRA (name-epoch:version-release.arch)."
msgstr "Søk i pakkenavn og NEVRA (name-epoch:version-release.arch)."

#: dnfdragora/dialogs.py:1537
msgid "&Provides"
msgstr "&Gir"

#: dnfdragora/dialogs.py:1539
msgid "Also match packages whose Provides: tags include the search pattern."
msgstr "Finn også pakker der Provides:-taggene inneholder søkemønsteret."

#: dnfdragora/dialogs.py:1540
msgid "&Files"
msgstr "&Filer"

#: dnfdragora/dialogs.py:1542
msgid "Match packages that own files whose path matches the pattern."
msgstr ""
"Samsvarer med pakker som eier filer med en sti som samsvarer med mønsteret."

#: dnfdragora/dialogs.py:1545
msgid "&Binaries"
msgstr "&Binærfiler"

#: dnfdragora/dialogs.py:1547
msgid ""
"Restrict file matching to /usr/bin and /usr/sbin only (subset of Files)."
msgstr "Begrens filmatching til kun /usr/bin og /usr/sbin (delsett av Filer)."

