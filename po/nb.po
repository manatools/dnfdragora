msgstr "Nedlasting:  %(d)s"

#: dnfdragora/progress_ui.py:307
#, python-format
msgid "Verifying %(n)d packages"
msgstr "Verifiserer %(n)d pakker"

#: dnfdragora/progress_ui.py:308
msgid "Verifying packages"
msgstr "Verifiserer pakker"

#: dnfdragora/progress_ui.py:322
#, python-format
msgid "Preparing transaction: %(n)d packages"
msgstr "Forbereder transaksjon%(n)dpakker"

#: dnfdragora/progress_ui.py:323
msgid "Preparing transaction"
msgstr "Forbereder transaksjonen"

#: dnfdragora/progress_ui.py:337
#, python-format
msgid "Processing: %(n)s"
msgstr "Prosesserer: %(n)s"

#: dnfdragora/progress_ui.py:362
#, python-format
msgid "Scriptlet: %(n)s  [%(t)s]"
msgstr "Lite skript%(n)s[%(t)s]"

