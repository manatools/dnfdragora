#: dnfdragora/helpinfo.py:65
msgid ""
"dnfdragora is a DNF frontend, based on Mageia rpmdragora layout and Fedora "
"yumex-dnf interaction with dnfdaemon.<br><br>"
msgstr ""
"dnfdragora er en DNF-frontend, basert på Mageia rpmdragora-layout og Fedora "
"yumex-dnf-interaksjon med dnfdaemon.<br><br>"

#: dnfdragora/helpinfo.py:66
msgid ""
"dnfdragora is basically a package manager user interface that allows you to "
"install, update, remove, and search for packages and more.<br><br>"
msgstr ""
"dnfdragora er i utgangspunktet et brukergrensesnitt for pakkebehandler som "
"lar deg installere, oppdatere, fjerne og søke etter pakker og mer.<br><br>"

#: dnfdragora/helpinfo.py:67
msgid ""
"dnfdragora is part of manatools and it is based on manatools.aui so that it "
"can work using Qt (PySide6), GTK 4, or ncurses, i.e. both graphical and "
"textual user interfaces.<br><br>"
msgstr ""
"dnfdragora er en del av manatools og er basert på manatools.aui slik at den "
"kan fungere med Qt (PySide6), GTK 4 eller ncurses, dvs. både grafiske og "
"tekstlige brukergrensesnitt.<br><br>"

#: dnfdragora/helpinfo.py:68
msgid "dnfdragora window is comprised of:"
msgstr "dnfdragora-vinduet består av:"

#: dnfdragora/helpinfo.py:73
msgid "Menu bar content"
msgstr "Innhold på menylinjen"

#: dnfdragora/helpinfo.py:75
msgid "Menu bar contains dnfdragora drop down menus:"
msgstr "Menylinjen inneholder dnfdragora-rullegardinmenyer:"

#: dnfdragora/helpinfo.py:83
msgid "File Menu"
msgstr "Filmeny"

#: dnfdragora/helpinfo.py:85
msgid "<h2>Reset selection</h2>"
msgstr "<h2>Tilbakestill valget</h2>"

#: dnfdragora/helpinfo.py:86
msgid ""
"This menu removes any flags on packages; if any packages have been selected "
"for installation or removal, they will be reset to their previous status.<br>"
msgstr ""
"Denne menyen fjerner eventuelle flagg på pakker. Hvis noen pakker er valgt "
"for installasjon eller fjerning, vil de bli tilbakestilt til sin tidligere "
"status.<br>"

#: dnfdragora/helpinfo.py:87
msgid "<h2>Refresh metadata</h2>"
msgstr "<h2>Oppfrisk metadata</h2>"

#: dnfdragora/helpinfo.py:88
msgid ""
"This menu sends a request to dnfdaemon to force a refresh of all the "
"metadata. This action is asynchronous and requires rebuilding the package "
"information cache.<br>"
msgstr ""
"Denne menyen sender en forespørsel til dnfdaemon om å fremtvinge en "
"oppdatering av alle metadataene. Denne handlingen er asynkron og krever "
"gjenoppbygging av pakkeinformasjonsbufferen.<br>"

#: dnfdragora/helpinfo.py:89
msgid "<h2>Repositories</h2>"
msgstr "<h2>Programvarebrønner</h2>"

#: dnfdragora/helpinfo.py:90
msgid "This menu opens the Repository Management dialog.<br>"
msgstr "Denne menyen åpner dialogboksen for administrasjon av arkiv.<br>"

#: dnfdragora/helpinfo.py:91
msgid ""
"The dialog lists all configured repositories sorted by name. You can enable "
"or disable each repository using its checkbox. Changes take effect "
"immediately for the current session but are not permanent.<br><br>"
msgstr ""
"Dialogboksen viser alle konfigurerte arkiver sortert etter navn. Du kan "
"aktivere eller deaktivere hvert arkiv ved å bruke avmerkingsboksen. "
"Endringer trer i kraft umiddelbart for gjeldende økt, men er ikke permanente."
"<br><br>"

#: dnfdragora/helpinfo.py:92
msgid "<b>Filter frame \\u2014 Show additional repository types</b><br>"
msgstr "<b>Filterramme \\u2014 Vis flere depottyper1</b><br>"

#: dnfdragora/helpinfo.py:93
msgid ""
"By default the list hides debug-information, source, and testing "
"repositories. Expand the filter frame by checking its title to show three "
"additional checkboxes:<br>"
msgstr ""
"Som standard skjuler listen feilsøkingsinformasjon, kilde og testlagre. "
"Utvid filterrammen ved å merke av i tittelen for å vise tre ekstra "
"avmerkingsbokser:<br>"

#: dnfdragora/helpinfo.py:94
msgid "<ul>"
msgstr "<ul>"

#: dnfdragora/helpinfo.py:95
msgid ""
"<li><b>Debug information</b>: show repositories whose id ends with <i>-"
"debuginfo</i>.</li>"
msgstr ""
"<li><b>Debug informasjon</b>: vis arkiver med ID som slutter med<i>-"
"debuginfo</i>.</li>"

#: dnfdragora/helpinfo.py:96
msgid ""
"<li><b>Source</b>: show repositories whose id ends with <i>-source</i>.</li>"
msgstr ""
"<li><b>Kilde</b>: vis arkiver med ID som slutter med<i>-kilde</i>.</li>"

#: dnfdragora/helpinfo.py:97
msgid ""
"<li><b>Testing</b>: show repositories whose id contains <i>testing</i>.</li>"
msgstr ""
"<li><b>Testing</b>: vis arkiver hvis ID inneholder <i>testing</i>.</li>"

#: dnfdragora/helpinfo.py:98
msgid "</ul>"
msgstr "</ul>"

#: dnfdragora/helpinfo.py:99
msgid ""
"If any repository of those types is currently <b>enabled</b> in DNF, the "
"corresponding checkbox is automatically turned on and the frame is expanded, "
"ensuring an active repository is never hidden.<br>"
msgstr ""
"Hvis det finnes et arkiv av disse typene som for øyeblikket <b>er aktivert</"
"b> i DNF, Den tilhørende avmerkingsboksen slås automatisk på og rammen "
"utvides, noe som sikrer at et aktivt arkiv aldri skjules.<br>"

#: dnfdragora/helpinfo.py:100
msgid ""
"The filter selections are saved in the user configuration file and restored "
"at the next launch.<br>"
msgstr ""
"Filtervalgene lagres i brukerkonfigurasjonsfilen og gjenopprettes ved neste "
"oppstart.<br>"

#: dnfdragora/helpinfo.py:101
msgid "<h2>Quit</h2>"
msgstr "<h2>Avsluttt</h2>"

#: dnfdragora/helpinfo.py:102
msgid "This menu exits from dnfdragora.<br>"
msgstr "Denne menyen avslutter dnfdragora.<br>"

#: dnfdragora/helpinfo.py:109
msgid "Information Menu"
msgstr "Informasjonsmeny"

#: dnfdragora/helpinfo.py:111
msgid "<h2>History</h2>"
msgstr "<h2>Historikk</h2>"

#: dnfdragora/helpinfo.py:112
msgid ""
"This menu runs a dialog containing transaction history shown in a tree "
"ordered by date. Selected history can be undone by pressing <b>Undo</b> "
"button.<br>"
msgstr ""
"Denne menyen kjører en dialogboks som inneholder transaksjonshistorikk vist "
"i et tre sortert etter dato. Valgt historie kan angres ved å trykke på "
"<b>Angre</b> knappen.<br>"

#: dnfdragora/helpinfo.py:113
msgid ""
"<br><i>Note that this function is currently broken because of a DNF API "
"change</i><br>"
msgstr ""
"<br><i>Merk at denne funksjonen for øyeblikket er ødelagt på grunn av en "
"endring i DNF API</i><br>"

#: dnfdragora/helpinfo.py:120
msgid "Option Menu"
msgstr "Meny for alternativer"

#: dnfdragora/helpinfo.py:122
msgid "<h2>User preferences</h2>"
msgstr "<h2>Brukerpreferanser</h2>"

#: dnfdragora/helpinfo.py:123
#, python-format
msgid ""
"This menu opens a %s containing user settings to customize dnfdragora "
"behavior.<br>"
msgstr ""
"Denne menyen åpner %s som inneholder brukerinnstillinger for å tilpasse "
"dnfdragora-oppførselen.<br>"

#: dnfdragora/helpinfo.py:123
msgid "dialog"
msgstr "dialog"

#: dnfdragora/helpinfo.py:131
msgid ""
"This dialog allows to customize dnfdragora behavior by changing options. "
"Some changes are available after closing the dialog, others need a "
"dnfdragora restart.<br><br>"
msgstr ""
"Denne dialogen lar deg tilpasse dnfdragoras-oppførsel ved å endre "
"alternativer. Noen endringer er tilgjengelige etter å ha lukket dialogen, "
"andre trenger en dnfdragora-omstart.<br><br>"

#: dnfdragora/helpinfo.py:132
msgid "<h2>System options</h2>"
msgstr "<h2>System alternativer</h2>"

#: dnfdragora/helpinfo.py:133
msgid ""
"<ul><li><b>Run transactions on packages automatically without confirmation "
"needed</b>: if checked transactions do not need to be confirmed, dnfdragora "
"works as answering always <i>yes</i>."
msgstr ""
"<ul><li><b>Kjør transaksjoner på pakker automatisk uten bekreftelse</b>: "
"hvis avmerkede transaksjoner ikke trenger å bli bekreftet, antar dnfdragora  "
"tid som svar <i>ja</i>."

#: dnfdragora/helpinfo.py:134
msgid ""
"<br><b>NOTE</b> that this option means that also removing packages is "
"silently accepted</li>"
msgstr ""
"<br><b>NOTE</b> at dette alternativet betyr at også å fjerne pakker "
"automatisk aksepteres</li>"

#: dnfdragora/helpinfo.py:135
msgid ""
"<li><b>Consider packages to upgrade as updates</b>: if checked upgrades are "
"added to updates and filtered as updates.</li>"
msgstr ""
"<li><b>Vurder pakker som skal oppgraderes som oppdateringer</b>: hvis det er "
"merket av, legges oppgraderinger til oppdateringer og filtreres som "
"oppdateringer.</li>"

#: dnfdragora/helpinfo.py:136
msgid ""
"<li><b>Hide dnfdragora-update menu if there are no updates</b>: if checked "
"dnfdragora update is hidden if there are no updates."
msgstr ""
"<li><b>Skjul dnfdragora-oppdateringsmenyen hvis det ikke er noen "
"oppdateringer</b>:hvis avmerket er dnfdragora-oppdateringen skjult dersom "
"det ikke finnes noen oppdateringer."

#: dnfdragora/helpinfo.py:137
msgid ""
"<br><b>NOTE</b> that this option is experimental, not all desktops manage it "
"as expected</li>"
msgstr ""
"<br><b>OBS</b>Ettersom dette alternativet er eksperimentelt, vil ikke alle "
"stasjonære datamaskiner klare det slik som forventet</li>"

#: dnfdragora/helpinfo.py:138
msgid ""
"<li><b>Interval to check for updates</b>: the given number represents how "
"often dnfdragora checks for updates; the value is expressed in minutes</li>"
msgstr ""
"<li><b>intervall for å sjekke etter oppdateringer 2: det gitte tallet "
"representerer hvor ofte dnfdragora sjekker etter oppdateringer; verdien "
"uttrykkes i minutter</li>"

#: dnfdragora/helpinfo.py:139
msgid ""
"<li><b>Metadata expire time</b>: time to force Metadata expiration, the "
"value is expressed in hours</li></ul>"
msgstr ""
"<li><b>Metadata utløpstid</b>: tid når å tvinge Metadata utløpstid, verdien "
"uttrykkes i timer</li></ul>"

#: dnfdragora/helpinfo.py:140
msgid "<h2>Layout options</h2>"
msgstr "<h2>Layout alternativer</h2>"

#: dnfdragora/helpinfo.py:141
msgid ""
"<ul><li><b>Show updates</b>: if checked dnfdragora starts with <i>updates</"
"i> filter active, i.e. showing only package available for updates if any.</"
"li>"
msgstr ""
"<ul><li><b>Vis oppdateringer</b>: Hvis markert startes dnfdragora med "
"<i>oppdaterings</i> filter aktivert,dvs.. viser bare pakkers som er "
"tilgjengelige for oppdatering.</li>"

#: dnfdragora/helpinfo.py:142
msgid ""
"<li><b>Do not show groups view</b>: filtering by groups could require CPU if "
"using comps, if this option is checked dnfdragora starts showing all "
"packages.</li></ul>"
msgstr ""
"<li><b>Ikke vis gruppevisning</b>: filtrering etter grupper kan kreve CPU "
"dersom du brukerkomposittangivelse. Dersom dette alternativet er markert, "
"vil dnfdragora starte med å vise alle pakkene.</li></ul>"

#: dnfdragora/helpinfo.py:143
msgid "<b>NOTE</b> that the above options require dnfdragora to be restarted."
msgstr ""
"<b>NOTER</b> at ovenstående alternativer krever at  dnfdragora må startes på "
"nytt."

#: dnfdragora/helpinfo.py:144
msgid "<h2>Logging options</h2>"
msgstr "<h2>Loggings alternativer</h2>"

#: dnfdragora/helpinfo.py:145
msgid ""
"Enable these options to let dnfdragora log on file called <i>dnfdragora.log</"
"i>."
msgstr ""
" Aktiver disse alternativene for å la dnfdragora logge på filen som heter "
"<i>dnfdragora.log</i>."

#: dnfdragora/helpinfo.py:146
msgid ""
"<ul><li><b>Change directory</b>: this option allows you to set the logging "
"directory; the directory must exist and needs write permission.</li>"
msgstr ""
"<ul><li><b>Endre katalog</b>: Dette alternativet lar deg angi "
"loggføringskatalogen. Katalogen må finnes og trenger skrivetillatelse..</li>"

#: dnfdragora/helpinfo.py:147
msgid ""
"<li><b>Debug level</b>: if checked, verbose logging is enabled.</li></ul>"
msgstr ""
"<li><b>Debug nivå</b>: Hvis det er avmerket, er detaljert logging aktivert.</"
"li></ul>"

#: dnfdragora/helpinfo.py:155
msgid "Help Menu"
msgstr "Hjelpe Meny"

#: dnfdragora/helpinfo.py:157
msgid "<h2>Manual</h2>"
msgstr "<h2>Manual</h2>"

#: dnfdragora/helpinfo.py:158
msgid "This menu opens dnfdragora help dialog."
msgstr "Denne menyen åpner dnfdragoras hjelpemeny"

#: dnfdragora/helpinfo.py:159
msgid "<h2>About</h2>"
msgstr "<h2>Om</h2>"

#: dnfdragora/helpinfo.py:160
msgid "This menu opens dnfdragora about dialog."
msgstr "Denne menyen åpner dnfdragoras om dialog"

#: dnfdragora/helpinfo.py:170
msgid "<h2>Views</h2>"
msgstr "<h2>Visninger</h2>"

#: dnfdragora/helpinfo.py:171
msgid ""
"The first combobox allows you to show packages by groups. If <i>Groups</i> "
"is selected, the group panel shows a tree view containing groups, and "
"selecting a group shows related packages in the package panel.<br>"
msgstr ""
"Den første kombinasjonsboksen lar deg vise pakker etter grupper. Hvis "
"<i>Grupper</i> iNår det er valgt, viser gruppepanelet en trevisning som "
"inneholder grupper, og når du velger en gruppe, vises relaterte pakker i "
"pakkepanelet.<br>"

#: dnfdragora/helpinfo.py:172
msgid ""
"If <i>All</i> is selected, the package panel contains all the packages.<br>"
msgstr "Hvis <i>Alle</i> er valgt, inneholder pakkepanelet alle pakkene.<br>"

#: dnfdragora/helpinfo.py:173
msgid "<h2>Filters</h2>"
msgstr "<h2>Filtre</h2>"

#: dnfdragora/helpinfo.py:174
msgid ""
"The Filter combobox allows you to filter the packages shown in the package "
"panel by:"
msgstr ""
"Kombinasjonsboksen Filter lar deg filtrere pakkene som vises i pakkepanelet "
"etter:"

#: dnfdragora/helpinfo.py:176
msgid "<li><b>Installed</b>: shows installed packages only.</li>"
msgstr "<li><b>Installedrt</b>: viser bare installerte pakker.</li>"

#: dnfdragora/helpinfo.py:177
msgid "<li><b>Not installed</b>: shows available packages only.</li>"
msgstr "<li><b>Ikke installert</b>: viser tilgjengelige pakker.</li>"

#: dnfdragora/helpinfo.py:178
msgid ""
"<li><b>To update</b>: shows packages that are available for updates only.</"
"li>"
msgstr ""
"<li><b>Oppdatering</b>: sviser pakker som bare er tilgjengelige for "
"oppdateringer.</li>"

#: dnfdragora/helpinfo.py:179
msgid ""
"<li><b>Show x86_64 and noarch only</b>: if dnfdragora is running on x86_64 "
"architecture, it hides i686 packages.</li>"
msgstr ""
"<li><b>Vis kun x86_64 og noarch</b>: Hvis dnfdragora kjører på x86_64-"
"arkitektur, skjules i686-pakker.</li>"

#: dnfdragora/helpinfo.py:180
msgid ""
"<li><b>All</b>: shows all the packages, i.e. available, updates and "
"installed.</li>"
msgstr ""
"<li><b>Alel</b>:viser alle pakkene, dvs. tilgjengelige, oppdateringer og "
"installerte.</li>"

#: dnfdragora/helpinfo.py:182
msgid "<h2>Search</h2>"
msgstr "<h2>Søk</h2>"

#: dnfdragora/helpinfo.py:183
#, python-format
msgid "Pressing the <b>Search</b> button (magnifier icon) opens the %s "
msgstr "Klikk på <b>Søk</b> knappen (forstørrelsesglassikonet) åpner%s "

#: dnfdragora/helpinfo.py:184
msgid ""
"that provides full-featured package search. When a search is active the "
"filter combobox is disabled "
msgstr ""
"som tilbyr fullfunksjons pakkesøk. Når et søk er aktivt, er "
"filterkombinasjonsboksen deaktivert"

#: dnfdragora/helpinfo.py:185
msgid "and an info label shows the active search text or dependency query. "
msgstr ""
"og en infoetikett viser den aktive søketeksten eller avhengighetsspørringen"

#: dnfdragora/helpinfo.py:186
msgid ""
"The <b>Clear search</b> button (eraser icon) next to the Search button "
"resets all search state "
msgstr ""
"<b>1Fjern søk</b>-knappen (viskelærikonet) ved siden av søkeknappen "
"tilbakestiller all søkestatus"

#: dnfdragora/helpinfo.py:187
msgid "and re-enables the filter combobox.<br>"
msgstr "og aktiverer filterkombinasjonsboksen på nytt.<br>"

#: dnfdragora/helpinfo.py:197
msgid ""
"This panel shows all the groups available to filter packages, if the Groups "
"view is selected. The special group <i>Search</i> is added after a search is "
"performed."
msgstr ""
"Dette panelet viser alle gruppene som er tilgjengelige for å filtrere "
"pakker, hvis Grupper-visningen er valgt. Den spesielle gruppen<i>Søk</i> "
"legges til etter at et søk er utført."

#: dnfdragora/helpinfo.py:207
msgid ""
"This panel shows all the filtered packages with their basic information such "
"as <i>name</i>, <i>summary</i>, <i>version</i>, <i>release</i>, "
"<i>architecture</i>, <i>size</i>, and <i>status</i>."
msgstr ""
"Dette panelet viser alle de filtrerte pakkene med grunnleggende informasjon, "
"for eksempel<i>navn</i>, <i>sammendrag</i>, <i>versjon</i>, <i>utgivelse</"
"i>, <i>arkitektur</i>, <i>størrelse</i>, og <i>status</i>."

#: dnfdragora/helpinfo.py:208
msgid ""
"A checkbox for any packages is available to add related package to "
"transaction for installing, updating or removing."
msgstr ""
"En avkrysningsrute for pakker er kan brukes for å legge en relatert pakke "
"for installasjon, oppdatering eller fjerning."

#: dnfdragora/helpinfo.py:218
msgid ""
"This panel shows all the package information such as <i>description</i>, "
"<i>URL</i>, <i>repository</i>, <i>requirements</i>, <i>file list</i>, and "
"<i>changelog</i>."
msgstr ""
"Dette panelet viser all pakkeinformasjon som f.eks<i>beskrivelse</i>, "
"<i>URL</i>, <i>lager</i>, <i>krav</i>, <i>fil liste</i>, og <i>endringslogg</"
"i>."

#: dnfdragora/helpinfo.py:219
msgid ""
"<br><br><i>Note that changelog is not provided by dnfdaemon at the moment.</"
"i>"
msgstr "<br><br><i>Noter at endringslogg ikke finnes for dnfdaemon nå.</i>"

#: dnfdragora/helpinfo.py:227
msgid "Progress bar"
msgstr "Framdriftslinje"

#: dnfdragora/helpinfo.py:229
msgid ""
"Progress bar shows dnfdragora operations progression such as transactions "
"and caching data."
msgstr ""
"Fremdriftslinje viser progresjon av dnfdragora-operasjoner som transaksjoner "
"og mellomlagrings-data."

#: dnfdragora/helpinfo.py:237
msgid "Buttons line"
msgstr "Knappe linje"

#: dnfdragora/helpinfo.py:239
msgid ""
"<ul><li><b>Apply</b>: when some packages are selected for installing or "
"updating or deselected for uninstalling this button runs the transaction to "
"be performed.</li>"
msgstr ""
"<ul><li><b>Bruk</b>: når noen pakker er valgt for å installere eller "
"oppdateres, eller fjerne valg for å avinstallering aktiverer denne knappen "
"transaksjonen som skal kjøres.</li>"

#: dnfdragora/helpinfo.py:240
msgid ""
"<li><b>Select all</b>: if packages are filtered for updates only this button "
"allows to select all the packages in one shot.</li>"
msgstr ""
"<li><b>Velg allel</b>: Hvis pakker er filtrert for oppdateringer, er det "
"bare denne knappen som gjør det mulig å velge alle pakkene på samme gang.</"
"li>"

#: dnfdragora/helpinfo.py:241
msgid "<li><b>Quit</b>: exits from dnfdragora.</li></ul>"
msgstr "<li><b>Avslutt </b>: går ut av dnfdragora.</li></ul>"

