#: dnfdragora/helpinfo.py:76
msgid ""
"dnfdragora is a DNF frontend, based on Mageia rpmdragora layout and Fedora "
"yumex-dnf interaction with dnfdaemon.<br><br>"
msgstr ""
"dnfdragora هو واجهة أمامية لـ DNF، مبني على تخطيط rpmdragora من ماجيا وتفاعل "
"yumex-dnf من فيدورا مع dnfdaemon.<br><br>"

#: dnfdragora/helpinfo.py:77
msgid ""
"dnfdragora is basically a package manager user interface that allows you to "
"install, update, remove, and search for packages and more.<br><br>"
msgstr ""
"dnfdragora هو في الأساس واجهة مستخدم لإدارة الحزم تسمح لك بتثبيت وتحديث "
"وإزالة والبحث عن الحزم وأكثر.<br><br>"

#: dnfdragora/helpinfo.py:78
msgid ""
"dnfdragora is part of manatools and it is based on manatools.aui so that it "
"can work using Qt (PySide6), GTK 4, or ncurses, i.e. both graphical and "
"textual user interfaces.<br><br>"
msgstr ""
"dnfdragora هو جزء من manatools ومبني على manatools.aui بحيث يمكنه العمل "
"باستخدام Qt (PySide6) أو GTK 4 أو ncurses، أي واجهات مستخدم رسومية ونصية على "
"حد سواء.<br><br>"

#: dnfdragora/helpinfo.py:79
msgid "dnfdragora window is comprised of:"
msgstr "نافذة dnfdragora تتكون من:"

#: dnfdragora/helpinfo.py:84
msgid "Menu bar content"
msgstr "محتوى شريط القائمة"

#: dnfdragora/helpinfo.py:86
msgid "Menu bar contains dnfdragora drop down menus:"
msgstr "شريط القائمة يحتوي على قوائم dnfdragora المنسدلة:"

#: dnfdragora/helpinfo.py:94
msgid "File Menu"
msgstr "قائمة ملف"

#: dnfdragora/helpinfo.py:96
msgid "<h2>Reset selection</h2>"
msgstr "<h2>إعادة تعيين التحديد</h2>"

#: dnfdragora/helpinfo.py:97
msgid ""
"This menu removes any flags on packages; if any packages have been selected "
"for installation or removal, they will be reset to their previous status.<br>"
msgstr ""
"هذه القائمة تزيل أي علامات على الحزم؛ إذا تم تحديد أي حزم للتثبيت أو "
"الإزالة، فسيتم إعادتها إلى حالتها السابقة.<br>"

#: dnfdragora/helpinfo.py:98
msgid "<h2>Refresh metadata</h2>"
msgstr "<h2>تحديث البيانات الوصفية</h2>"

#: dnfdragora/helpinfo.py:99
msgid ""
"This menu sends a request to dnfdaemon to force a refresh of all the "
"metadata. This action is asynchronous and requires rebuilding the package "
"information cache.<br>"
msgstr ""
"هذه القائمة ترسل طلباً إلى dnfdaemon لفرض تحديث كل البيانات الوصفية. هذا "
"الإجراء غير متزامن ويتطلب إعادة بناء خابئ معلومات الحزم.<br>"

#: dnfdragora/helpinfo.py:100
msgid "<h2>Repositories</h2>"
msgstr "<h2>المستودعات</h2>"

#: dnfdragora/helpinfo.py:101
msgid "This menu opens the Repository Management dialog.<br>"
msgstr "هذه القائمة تفتح حوار إدارة المستودعات.<br>"

#: dnfdragora/helpinfo.py:102
msgid ""
"The dialog lists all configured repositories sorted by name. You can enable "
"or disable each repository using its checkbox. Changes take effect "
"immediately for the current session but are not permanent.<br><br>"
msgstr ""
"يسرد الحوار جميع المستودعات المكونة مرتبة حسب الاسم. يمكنك تمكين أو تعطيل كل "
"مستودع باستخدام مربع الاختيار الخاص به. تدخل التغييرات حيز التنفيذ فوراً "
"للجلسة الحالية ولكنها ليست دائمة.<br><br>"

#: dnfdragora/helpinfo.py:103
msgid "<b>Filter frame \\u2014 Show additional repository types</b><br>"
msgstr "<b>إطار الفلتر \\u2014 إظهار أنواع المستودعات الإضافية</b><br>"

#: dnfdragora/helpinfo.py:104
msgid ""
"By default the list hides debug-information, source, and testing "
"repositories. Expand the filter frame by checking its title to show three "
"additional checkboxes:<br>"
msgstr ""
"بشكل افتراضي، تخفي القائمة مستودعات معلومات التصحيح والمصدر والاختبار. وسّع "
"إطار الفلتر بوضع علامة على عنوانه لإظهار ثلاثة مربعات اختيار إضافية:<br>"

#: dnfdragora/helpinfo.py:105 dnfdragora/helpinfo.py:279
#: dnfdragora/helpinfo.py:286 dnfdragora/helpinfo.py:294
#: dnfdragora/helpinfo.py:301
msgid "<ul>"
msgstr "<ul>"

#: dnfdragora/helpinfo.py:106
msgid ""
"<li><b>Debug information</b>: show repositories whose id ends with <i>-"
"debuginfo</i>.</li>"
msgstr ""
"<li><b>معلومات التصحيح</b>: إظهار المستودعات التي ينتهي معرفها بـ <i>-"
"debuginfo</i>.</li>"

#: dnfdragora/helpinfo.py:107
msgid ""
"<li><b>Source</b>: show repositories whose id ends with <i>-source</i>.</li>"
msgstr ""
"<li><b>المصدر</b>: إظهار المستودعات التي ينتهي معرفها بـ <i>-source</i>.</li>"

#: dnfdragora/helpinfo.py:108
msgid ""
"<li><b>Testing</b>: show repositories whose id contains <i>testing</i>.</li>"
msgstr ""
"<li><b>الاختبار</b>: إظهار المستودعات التي يحتوي معرفها على <i>testing</i>.</li>"

#: dnfdragora/helpinfo.py:109 dnfdragora/helpinfo.py:283
#: dnfdragora/helpinfo.py:291 dnfdragora/helpinfo.py:298
#: dnfdragora/helpinfo.py:308
msgid "</ul>"
msgstr "</ul>"

#: dnfdragora/helpinfo.py:110
msgid ""
"If any repository of those types is currently <b>enabled</b> in DNF, the "
"corresponding checkbox is automatically turned on and the frame is expanded, "
"ensuring an active repository is never hidden.<br>"
msgstr ""
"إذا كان أي مستودع من هذه الأنواع <b>مفعلًا</b> حالياً في DNF، يتم تشغيل مربع "
"الاختيار المقابل تلقائياً ويتم توسيع الإطار، مما يضمن عدم إخفاء أي مستودع "
"نشط.<br>"

#: dnfdragora/helpinfo.py:111
msgid ""
"The filter selections are saved in the user configuration file and restored "
"at the next launch.<br>"
msgstr ""
"يتم حفظ تحديدات الفلتر في ملف تكوين المستخدم واستعادتها عند التشغيل التالي.<br>"

#: dnfdragora/helpinfo.py:112
msgid "<h2>Quit</h2>"
msgstr "<h2>خروج</h2>"

#: dnfdragora/helpinfo.py:113
msgid "This menu exits from dnfdragora.<br>"
msgstr "هذه القائمة تخرج من dnfdragora.<br>"

#: dnfdragora/helpinfo.py:120
msgid "Information Menu"
msgstr "قائمة معلومات"

#: dnfdragora/helpinfo.py:122
msgid "<h2>History</h2>"
msgstr "<h2>السجل</h2>"

#: dnfdragora/helpinfo.py:123
#, python-format
msgid ""
"This menu opens the %s, which shows packages recently changed on the system."
msgstr ""
"هذه القائمة تفتح %s، الذي يعرض الحزم التي تم تغييرها مؤخراً على النظام."

#: dnfdragora/helpinfo.py:124
msgid "<h2>System upgrade</h2>"
msgstr "<h2>ترقية النظام</h2>"

#: dnfdragora/helpinfo.py:125
#, python-format
msgid ""
"This menu opens the %s to prepare an offline distro upgrade to a target "
"releasever. "
msgstr ""
"هذه القائمة تفتح %s لتحضير ترقية غير متصلة للتوزيعة إلى releasever هدف. "

#: dnfdragora/helpinfo.py:126
msgid ""
"<b>Important:</b> the menu entry is shown only when systemd is available, "
"because execution is scheduled offline for reboot."
msgstr ""
"<b>هام:</b> يُظهر إدخال القائمة فقط عندما يكون systemd متاحاً، لأن التنفيذ "
"يُجدول بشكل غير متصل لإعادة التشغيل."

#: dnfdragora/helpinfo.py:127
msgid "<h2>Advisory information</h2>"
msgstr "<h2>معلومات الاستشارات الأمنية</h2>"

#: dnfdragora/helpinfo.py:128
#, python-format
msgid ""
"This menu opens the %s to query advisory metadata (security, bugfix, "
"enhancement) with filters and inspect selected advisory details."
msgstr ""
"هذه القائمة تفتح %s للاستعلام عن البيانات الوصفية للاستشارات الأمنية (الأمن، "
"إصلاح الأخطاء، التحسين) مع فلاتر وفحص تفاصيل الاستشارة الأمنية المحددة."

#: dnfdragora/helpinfo.py:135
msgid "Option Menu"
msgstr "قائمة خيارات"

#: dnfdragora/helpinfo.py:137
msgid "<h2>User preferences</h2>"
msgstr "<h2>تفضيلات المستخدم</h2>"

#: dnfdragora/helpinfo.py:138
#, python-format
msgid ""
"This menu opens a %s containing user settings to customize dnfdragora "
"behavior.<br>"
msgstr ""
"هذه القائمة تفتح %s تحتوي على إعدادات المستخدم لتخصيص سلوك dnfdragora.<br>"

#: dnfdragora/helpinfo.py:138
msgid "dialog"
msgstr "حوار"

#: dnfdragora/helpinfo.py:146
msgid ""
"This dialog allows to customize dnfdragora behavior by changing options. "
"Some changes are available after closing the dialog, others need a "
"dnfdragora restart.<br><br>"
msgstr ""
"هذا الحوار يسمح بتخصيص سلوك dnfdragora عن طريق تغيير الخيارات. بعض التغييرات "
"تكون متاحة بعد إغلاق الحوار، والبعض الآخر يحتاج إلى إعادة تشغيل dnfdragora."
"<br><br>"

#: dnfdragora/helpinfo.py:147
msgid "<h2>System options</h2>"
msgstr "<h2>خيارات النظام</h2>"

#: dnfdragora/helpinfo.py:148
msgid ""
"<ul><li><b>Run transactions on packages automatically without confirmation "
"needed</b>: if checked transactions do not need to be confirmed, dnfdragora "
"works as answering always <i>yes</i>."
msgstr ""
"<ul><li><b>تنفيذ المعاملات على الحزم تلقائياً دون الحاجة إلى تأكيد</b>: إذا "
"تم التحديد، فالمعاملات لا تحتاج إلى تأكيد، ويعمل dnfdragora وكأنه يجيب دائماً "
"<i>نعم</i>."

#: dnfdragora/helpinfo.py:149
msgid ""
"<br><b>NOTE</b> that this option means that also removing packages is "
"silently accepted</li>"
msgstr ""
"<br><b>ملاحظة</b>: هذا الخيار يعني أن إزالة الحزم أيضاً يتم قبولها بصمت</li>"

#: dnfdragora/helpinfo.py:150
msgid ""
"<li><b>Force distsync as upgrade</b>: if enabled, queued upgrade actions are "
"resolved as distsync actions.</li>"
msgstr ""
"<li><b>فرض مزامنة التوزيعة كترقية</b>: إذا تم التمكين، يتم حل إجراءات الترقية "
"المعلقة كإجراءات مزامنة توزيعة.</li>"

#: dnfdragora/helpinfo.py:151
msgid ""
"<li><b>Remove installed package to resolve transactions</b>: if enabled, "
"dependency solving can remove installed packages (<i>allow_erasing</i>).</li>"
msgstr ""
"<li><b>إزالة الحزم المثبتة لحل المعاملات</b>: إذا تم التمكين، يمكن لحل "
"الاعتماديات إزالة الحزم المثبتة (<i>allow_erasing</i>).</li>"

#: dnfdragora/helpinfo.py:152
msgid ""
"<li><b>Metadata expire time</b>: time to force Metadata expiration, the "
"value is expressed in hours</li></ul>"
msgstr ""
"<li><b>مدة انتهاء صلاحية البيانات الوصفية</b>: الوقت لفرض انتهاء صلاحية "
"البيانات الوصفية، القيمة معبر عنها بالساعات</li></ul>"

#: dnfdragora/helpinfo.py:153
msgid "<h2>dnfdragora-updater options</h2>"
msgstr "<h2>خيارات محدّث dnfdragora</h2>"

#: dnfdragora/helpinfo.py:154
msgid ""
"<ul><li><b>Hide dnfdragora-update menu if there are no updates</b>: if "
"checked dnfdragora-update is hidden when no updates are available."
msgstr ""
"<ul><li><b>إخفاء قائمة تحديث dnfdragora إذا لم تكن هناك تحديثات</b>: إذا تم "
"التحديد، يتم إخفاء تحديث dnfdragora عندما لا تكون هناك تحديثات متاحة."

#: dnfdragora/helpinfo.py:155
msgid ""
"<br><b>NOTE</b> that this option is experimental, not all desktops manage it "
"as expected</li>"
msgstr ""
"<br><b>ملاحظة</b>: هذا الخيار تجريبي، وليس كل أسطح المكتب تديره كما هو "
"متوقع</li>"

#: dnfdragora/helpinfo.py:156
msgid ""
"<li><b>Interval to check for updates</b>: how often dnfdragora-update checks "
"for updates; value is expressed in minutes (10..10080).</li></ul>"
msgstr ""
"<li><b>الفاصل الزمني للتحقق من التحديثات</b>: كم مرة يتحقق تحديث dnfdragora من "
"التحديثات؛ القيمة معبر عنها بالدقائق (10..10080).</li></ul>"

#: dnfdragora/helpinfo.py:157
msgid "<h2>Layout options</h2>"
msgstr "<h2>خيارات التخطيط</h2>"

#: dnfdragora/helpinfo.py:158
msgid ""
"<ul><li><b>Show updates</b>: if checked dnfdragora starts with <i>updates</"
"i> filter active, i.e. showing only package available for updates if any.</"
"li>"
msgstr ""
"<ul><li><b>إظهار التحديثات</b>: إذا تم التحديد، يبدأ dnfdragora مع فلتر "
"<i>التحديثات</i> نشطاً، أي إظهار الحزم المتاحة للتحديث فقط إن وجدت.</li>"

#: dnfdragora/helpinfo.py:159
msgid ""
"<li><b>Do not show groups view</b>: filtering by groups could require CPU if "
"using comps, if this option is checked dnfdragora starts showing all "
"packages.</li></ul>"
msgstr ""
"<li><b>عدم إظهار عرض المجموعات</b>: التصفية حسب المجموعات قد تستهلك المعالج "
"إذا تم استخدام comps، إذا تم تحديد هذا الخيار، يبدأ dnfdragora بإظهار كل "
"الحزم.</li></ul>"

#: dnfdragora/helpinfo.py:160
msgid "<b>NOTE</b> that the above options require dnfdragora to be restarted."
msgstr "<b>ملاحظة</b>: الخيارات أعلاه تتطلب إعادة تشغيل dnfdragora."

#: dnfdragora/helpinfo.py:161
msgid "<h2>Logging options</h2>"
msgstr "<h2>خيارات تسجيل الأحداث</h2>"

#: dnfdragora/helpinfo.py:162
msgid ""
"Enable these options to let dnfdragora log on file called <i>dnfdragora.log</"
"i>."
msgstr ""
"قم بتمكين هذه الخيارات للسماح لـ dnfdragora بتسجيل الأحداث في ملف يسمى "
"<i>dnfdragora.log</i>."

#: dnfdragora/helpinfo.py:163
msgid ""
"<ul><li><b>Change directory</b>: this option allows you to set the logging "
"directory; the directory must exist and needs write permission.</li>"
msgstr ""
"<ul><li><b>تغيير المجلد</b>: هذا الخيار يسمح لك بتعيين مجلد تسجيل الأحداث؛ "
"يجب أن يكون المجلد موجوداً ويحتاج إلى إذن كتابة.</li>"

#: dnfdragora/helpinfo.py:164
msgid ""
"<li><b>Debug level</b>: if checked, verbose logging is enabled.</li></ul>"
msgstr ""
"<li><b>مستوى التصحيح</b>: إذا تم التحديد، يتم تمكين تسجيل الأحداث المفصل.</"
"li></ul>"

#: dnfdragora/helpinfo.py:172
msgid "Help Menu"
msgstr "قائمة مساعدة"

#: dnfdragora/helpinfo.py:174
msgid "<h2>Manual</h2>"
msgstr "<h2>دليل</h2>"

#: dnfdragora/helpinfo.py:175
msgid "This menu opens dnfdragora help dialog."
msgstr "هذه القائمة تفتح حوار مساعدة dnfdragora."

#: dnfdragora/helpinfo.py:176
msgid "<h2>About</h2>"
msgstr "<h2>حول</h2>"

#: dnfdragora/helpinfo.py:177
msgid "This menu opens dnfdragora about dialog."
msgstr "هذه القائمة تفتح حوار حول dnfdragora."

#: dnfdragora/helpinfo.py:187
msgid "<h2>Views</h2>"
msgstr "<h2>طرق العرض</h2>"

#: dnfdragora/helpinfo.py:188
msgid ""
"The first combobox allows you to show packages by groups. If <i>Groups</i> "
"is selected, the group panel shows a tree view containing groups, and "
"selecting a group shows related packages in the package panel.<br>"
msgstr ""
"مربع التحرير والسرد الأول يتيح لك إظهار الحزم حسب المجموعات. إذا تم اختيار "
"<i>المجموعات</i>، تعرض لوحة المجموعات عرضاً شجرياً يحتوي على مجموعات، ويؤدي "
"اختيار مجموعة إلى إظهار الحزم ذات الصلة في لوحة الحزم.<br>"

#: dnfdragora/helpinfo.py:189
msgid ""
"If <i>All</i> is selected, the package panel contains all the packages.<br>"
msgstr "إذا تم اختيار <i>الكلّ</i>، تحتوي لوحة الحزم على كل الحزم.<br>"

#: dnfdragora/helpinfo.py:190 dnfdragora/helpinfo.py:277
#: dnfdragora/helpinfo.py:361
msgid "<h2>Filters</h2>"
msgstr "<h2>الفلاتر</h2>"

#: dnfdragora/helpinfo.py:191
msgid ""
"The Filter combobox allows you to filter the packages shown in the package "
"panel by:"
msgstr ""
"مربع تحرير وسرد الفلتر يسمح لك بتصفية الحزم المعروضة في لوحة الحزم حسب:"

#: dnfdragora/helpinfo.py:193
msgid "<li><b>Installed</b>: shows installed packages only.</li>"
msgstr "<li><b>مثبت</b>: يعرض الحزم المثبتة فقط.</li>"

#: dnfdragora/helpinfo.py:194
msgid "<li><b>Not installed</b>: shows available packages only.</li>"
msgstr "<li><b>غير مثبت</b>: يعرض الحزم المتاحة فقط.</li>"

#: dnfdragora/helpinfo.py:195
msgid ""
"<li><b>To update</b>: shows packages that are available for updates only.</"
"li>"
msgstr "<li><b>لتحديث</b>: يعرض الحزم المتاحة للتحديث فقط.</li>"

#: dnfdragora/helpinfo.py:196
msgid ""
"<li><b>Desktop Applications</b>: shows packages that provide desktop/GUI "
"applications.</li>"
msgstr ""
"<li><b>تطبيقات سطح المكتب</b>: يعرض الحزم التي توفر تطبيقات سطح المكتب/"
"الواجهة الرسومية.</li>"

#: dnfdragora/helpinfo.py:197
msgid ""
"<li><b>Show x86_64 and noarch only</b>: if dnfdragora is running on x86_64 "
"architecture, it hides i686 packages.</li>"
msgstr ""
"<li><b>إظهار x86_64 و noarch فقط</b>: إذا كان dnfdragora يعمل على معمارية "
"x86_64، فإنه يخفي حزم i686.</li>"

#: dnfdragora/helpinfo.py:198
msgid ""
"<li><b>All</b>: shows all the packages, i.e. available, updates and "
"installed.</li>"
msgstr ""
"<li><b>الكلّ</b>: يعرض كل الحزم، أي المتاحة والتحديثات والمثبتة.</li>"

#: dnfdragora/helpinfo.py:200
msgid "<h2>Search</h2>"
msgstr "<h2>البحث</h2>"

#: dnfdragora/helpinfo.py:201
#, python-format
msgid "Pressing the <b>Search</b> button (magnifier icon) opens the %s "
msgstr "الضغط على زر <b>البحث</b> (أيقونة العدسة المكبرة) يفتح %s "

#: dnfdragora/helpinfo.py:202
msgid ""
"that provides full-featured package search. When a search is active the "
"filter combobox is disabled "
msgstr ""
"الذي يوفر بحثاً كاملاً عن الحزم. عندما يكون البحث نشطاً، يتم تعطيل مربع تحرير "
"وسرد الفلتر "

#: dnfdragora/helpinfo.py:203
msgid "and an info label shows the active search text or dependency query. "
msgstr "وتظهر علامة معلومات نص البحث النشط أو استعلام الاعتماديات. "

#: dnfdragora/helpinfo.py:204
msgid ""
"The <b>Clear search</b> button (eraser icon) next to the Search button "
"resets all search state "
msgstr ""
"زر <b>مسح البحث</b> (أيقونة الممحاة) بجانب زر البحث يعيد تعيين كل حالة البحث "

#: dnfdragora/helpinfo.py:205
msgid "and re-enables the filter combobox.<br>"
msgstr "ويعيد تمكين مربع تحرير وسرد الفلتر.<br>"

#: dnfdragora/helpinfo.py:215
msgid ""
"This panel shows all the groups available to filter packages, if the Groups "
"view is selected. The special group <i>Search</i> is added after a search is "
"performed."
msgstr ""
"هذه اللوحة تعرض كل المجموعات المتاحة لتصفية الحزم، إذا تم اختيار عرض "
"المجموعات. تتم إضافة المجموعة الخاصة <i>البحث</i> بعد إجراء البحث."

#: dnfdragora/helpinfo.py:225
msgid ""
"This panel shows all the filtered packages with their basic information such "
"as <i>name</i>, <i>summary</i>, <i>version</i>, <i>release</i>, "
"<i>architecture</i>, <i>size</i>, and <i>status</i>."
msgstr ""
"هذه اللوحة تعرض كل الحزم المفلترة مع معلوماتها الأساسية مثل <i>الاسم</i>، "
"<i>الملخص</i>، <i>الإصدار</i>، <i>الإصدار الفرعي</i>، <i>المعمارية</i>، "
"<i>الحجم</i>، و<i>الحالة</i>."

#: dnfdragora/helpinfo.py:226
msgid ""
"A checkbox for any packages is available to add related package to "
"transaction for installing, updating or removing."
msgstr ""
"يتوفر مربع اختيار لأي حزمة لإضافة الحزمة ذات الصلة إلى المعاملة للتثبيت أو "
"التحديث أو الإزالة."

#: dnfdragora/helpinfo.py:236
msgid ""
"This panel shows all the package information such as <i>description</i>, "
"<i>URL</i>, <i>repository</i>, <i>requirements</i>, <i>file list</i>, and "
"<i>changelog</i>."
msgstr ""
"هذه اللوحة تعرض كل معلومات الحزمة مثل <i>الوصف</i>، <i>الرابط</i>، "
"<i>المستودع</i>، <i>المتطلبات</i>، <i>قائمة الملفات</i>، و<i>سجل التغييرات</"
"i>."

#: dnfdragora/helpinfo.py:237
msgid ""
"<br><br><i>Note that changelog is not provided by dnfdaemon at the moment.</"
"i>"
msgstr "<br><br><i>ملاحظة: سجل التغييرات غير متوفر حالياً من dnfdaemon.</i>"

#: dnfdragora/helpinfo.py:245
msgid "Progress bar"
msgstr "شريط التقدم"

#: dnfdragora/helpinfo.py:247
msgid ""
"Progress bar shows dnfdragora operations progression such as transactions "
"and caching data."
msgstr ""
"شريط التقدم يعرض تقدم عمليات dnfdragora مثل المعاملات وتخزين البيانات في "
"الخابئ."

#: dnfdragora/helpinfo.py:255
msgid "Buttons line"
msgstr "شريط الأزرار"

#: dnfdragora/helpinfo.py:257
msgid ""
"<ul><li><b>Apply</b>: when some packages are selected for installing or "
"updating or deselected for uninstalling this button runs the transaction to "
"be performed.</li>"
msgstr ""
"<ul><li><b>تطبيق</b>: عندما يتم تحديد بعض الحزم للتثبيت أو التحديث أو إلغاء "
"تحديدها للإزالة، يقوم هذا الزر بتنفيذ المعاملة المطلوبة.</li>"

#: dnfdragora/helpinfo.py:258
msgid ""
"<li><b>Select all</b>: if packages are filtered for updates only this button "
"allows to select all the packages in one shot.</li>"
msgstr ""
"<li><b>تحديد الكل</b>: إذا تمت تصفية الحزم للتحديثات فقط، فإن هذا الزر يسمح "
"بتحديد كل الحزم دفعة واحدة.</li>"

#: dnfdragora/helpinfo.py:259
msgid "<li><b>Quit</b>: exits from dnfdragora.</li></ul>"
msgstr "<li><b>خروج</b>: يخرج من dnfdragora.</li></ul>"

#: dnfdragora/helpinfo.py:260
msgid "<h2>Offline transaction confirmation</h2>"
msgstr "<h2>تأكيد المعاملة غير المتصلة</h2>"

#: dnfdragora/helpinfo.py:261
msgid ""
"When transaction confirmation is shown, you can enable <b>Offline</b> and "
"choose <b>Reboot</b> or <b>Power off</b>. "
msgstr ""
"عند عرض تأكيد المعاملة، يمكنك تمكين <b>غير متصل</b> واختيار <b>إعادة تشغيل</"
"b> أو <b>إيقاف التشغيل</b>. "

#: dnfdragora/helpinfo.py:262
msgid ""
"dnfdragora schedules the offline transaction and shows a reminder to reboot "
"or power off to continue at the next startup. "
msgstr ""
"يقوم dnfdragora بجدولة المعاملة غير المتصلة ويعرض تذكيراً بإعادة التشغيل أو "
"إيقاف التشغيل للمتابعة عند بدء التشغيل التالي. "

#: dnfdragora/helpinfo.py:263
msgid ""
"While offline scheduling is in progress, cancellation is disabled and the "
"progress window stays open until scheduling is completed."
msgstr ""
"أثناء جدولة الوضع غير المتصل، يتم تعطيل الإلغاء وتبقى نافذة التقدم مفتوحة حتى "
"اكتمال الجدولة."

#: dnfdragora/helpinfo.py:273
msgid ""
"The History dialog shows packages that have been recently changed on the "
"system by querying the dnf5daemon History API.<br><br>"
msgstr ""
"يعرض حوار السجل الحزم التي تم تغييرها مؤخراً على النظام عن طريق الاستعلام عن "
"واجهة برمجة تطبيقات السجل الخاصة بـ dnf5daemon.<br><br>"

#: dnfdragora/helpinfo.py:274 dnfdragora/helpinfo.py:325
#: dnfdragora/helpinfo.py:340 dnfdragora/helpinfo.py:359
msgid "<h2>Opening the dialog</h2>"
msgstr "<h2>فتح الحوار</h2>"

#: dnfdragora/helpinfo.py:275
msgid "Open the dialog from the menu bar: <b>Actions → History</b>.<br>"
msgstr "افتح الحوار من شريط القائمة: <b>إجراءات → السجل</b>.<br>"

#: dnfdragora/helpinfo.py:276 dnfdragora/helpinfo.py:327
msgid ""
"The main dnfdragora window is disabled while the dialog is open to prevent "
"unintended interactions.<br><br>"
msgstr ""
"يتم تعطيل نافذة dnfdragora الرئيسية أثناء فتح الحوار لمنع التفاعلات غير "
"المقصودة.<br><br>"

#: dnfdragora/helpinfo.py:278
msgid ""
"The <b>Filters</b> section at the top of the dialog lets you narrow the "
"results:<br>"
msgstr "يتيح لك قسم <b>الفلاتر</b> في أعلى الحوار تضييق النتائج:<br>"

#: dnfdragora/helpinfo.py:280
msgid ""
"<li><b>Since (YYYY-MM-DD)</b>: enter a date to show only packages changed on "
"or after that date. "
msgstr ""
"<li><b>منذ (YYYY-MM-DD)</b>: أدخل تاريخاً لإظهار الحزم التي تم تغييرها في أو "
"بعد ذلك التاريخ. "

#: dnfdragora/helpinfo.py:281
msgid "Leave empty to retrieve all available history. "
msgstr "اتركه فارغاً لجلب كل السجل المتاح. "

#: dnfdragora/helpinfo.py:282
msgid ""
"The date is converted to a Unix timestamp before being sent to the daemon.</"
"li>"
msgstr ""
"يتم تحويل التاريخ إلى طابع زمني Unix قبل إرساله إلى الخادم.</li>"

#: dnfdragora/helpinfo.py:284
msgid "<h2>Change type checkboxes</h2>"
msgstr "<h2>مربعات اختيار نوع التغيير</h2>"

#: dnfdragora/helpinfo.py:285
msgid ""
"Four checkboxes let you choose which kinds of package changes to include in "
"the results:<br>"
msgstr ""
"تتيح لك أربعة مربعات اختيار اختيار أنواع تغييرات الحزم التي تريد تضمينها في "
"النتائج:<br>"

#: dnfdragora/helpinfo.py:287
msgid "<li><b>Installed</b>: packages that were newly installed.</li>"
msgstr "<li><b>مثبت</b>: الحزم التي تم تثبيتها حديثاً.</li>"

#: dnfdragora/helpinfo.py:288
msgid "<li><b>Removed</b>: packages that were removed from the system.</li>"
msgstr "<li><b>مزال</b>: الحزم التي تمت إزالتها من النظام.</li>"

#: dnfdragora/helpinfo.py:289
msgid ""
"<li><b>Upgraded</b>: packages that were upgraded to a newer version.</li>"
msgstr "<li><b>محدث</b>: الحزم التي تمت ترقيتها إلى إصدار أحدث.</li>"

#: dnfdragora/helpinfo.py:290
msgid ""
"<li><b>Downgraded</b>: packages that were downgraded to an older version.</"
"li>"
msgstr "<li><b>مخفض الإصدار</b>: الحزم التي تم تخفيض إصدارها إلى إصدار أقدم.</"
"li>"

#: dnfdragora/helpinfo.py:292
msgid ""
"Uncheck any type you are not interested in to reduce the number of rows "
"shown.<br><br>"
msgstr ""
"قم بإلغاء تحديد أي نوع لست مهتماً به لتقليل عدد الصفوف المعروضة.<br><br>"

#: dnfdragora/helpinfo.py:293
msgid "<h2>Advisory options</h2>"
msgstr "<h2>خيارات الاستشارات الأمنية</h2>"

#: dnfdragora/helpinfo.py:295
msgid ""
"<li><b>Include advisories</b>: when checked, advisory information (security, "
"bugfix, enhancement) is included where available.</li>"
msgstr ""
"<li><b>تضمين الاستشارات الأمنية</b>: عند التحديد، يتم تضمين معلومات "
"الاستشارات الأمنية (الأمن، إصلاح الأخطاء، التحسين) حيثما كانت متاحة.</li>"

#: dnfdragora/helpinfo.py:296
msgid ""
"<li><b>All advisories</b>: when checked together with <i>Include advisories</"
"i>, all advisory types are returned rather than only the most relevant one "
"per package. "
msgstr ""
"<li><b>جميع الاستشارات الأمنية</b>: عند التحديد مع <i>تضمين الاستشارات "
"الأمنية</i>، يتم إرجاع جميع أنواع الاستشارات الأمنية بدلاً من النوع الأكثر "
"صلة فقط لكل حزمة. "

#: dnfdragora/helpinfo.py:297
msgid ""
"This option is automatically disabled when <i>Include advisories</i> is "
"unchecked.</li>"
msgstr ""
"يتم تعطيل هذا الخيار تلقائياً عند إلغاء تحديد <i>تضمين الاستشارات الأمنية</"
"i>.</li>"

#: dnfdragora/helpinfo.py:299 dnfdragora/helpinfo.py:363
msgid "<h2>Results table</h2>"
msgstr "<h2>جدول النتائج</h2>"

#: dnfdragora/helpinfo.py:300
msgid ""
"The table shows one row per changed package with the following columns:<br>"
msgstr "يعرض الجدول صفاً واحداً لكل حزمة تم تغييرها مع الأعمدة التالية:<br>"

#: dnfdragora/helpinfo.py:302
msgid "<li><b>Name</b>: the package name.</li>"
msgstr "<li><b>الاسم</b>: اسم الحزمة.</li>"

#: dnfdragora/helpinfo.py:303
msgid ""
"<li><b>EVR</b>: epoch:version-release of the new (installed) version.</li>"
msgstr "<li><b>EVR</b>: العصر:الإصدار-الإصدار الفرعي للإصدار الجديد (المثبت).</li>"

#: dnfdragora/helpinfo.py:304
msgid "<li><b>Arch</b>: the package architecture.</li>"
msgstr "<li><b>المعمارية</b>: معمارية الحزمة.</li>"

#: dnfdragora/helpinfo.py:305
msgid ""
"<li><b>Action</b>: one of <i>installed</i>, <i>removed</i>, <i>upgraded</i>, "
"or <i>downgraded</i>.</li>"
msgstr ""
"<li><b>الإجراء</b>: واحد من <i>مثبت</i>، <i>مزال</i>، <i>محدث</i>، أو "
"<i>مخفض الإصدار</i>.</li>"

#: dnfdragora/helpinfo.py:306
msgid ""
"<li><b>Date</b>: the date and time of the transaction (YYYY-MM-DD HH:MM).</"
"li>"
msgstr "<li><b>التاريخ</b>: تاريخ ووقت المعاملة (YYYY-MM-DD HH:MM).</li>"

#: dnfdragora/helpinfo.py:307
msgid "<li><b>Summary</b>: a short description of the package.</li>"
msgstr "<li><b>الملخص</b>: وصف قصير للحزمة.</li>"

#: dnfdragora/helpinfo.py:309
msgid ""
"If no packages match the current filters a <i>No results</i> row is shown."
"<br>"
msgstr "إذا لم تطابق أي حزمة الفلاتر الحالية، يتم عرض صف <i>لا توجد نتائج</i>.<br>"

#: dnfdragora/helpinfo.py:310
msgid ""
"If the daemon call fails the error message is displayed in the table so you "
"can diagnose the problem.<br><br>"
msgstr ""
"إذا فشلت استدعاء الخادم، يتم عرض رسالة الخطأ في الجدول حتى تتمكن من تشخيص "
"المشكلة.<br><br>"

#: dnfdragora/helpinfo.py:311
msgid "<h2>Refresh button</h2>"
msgstr "<h2>زر التحديث</h2>"

#: dnfdragora/helpinfo.py:312
msgid ""
"Press <b>Refresh</b> to re-query the daemon with the current filter "
"settings. "
msgstr "اضغط على <b>تحديث</b> لإعادة الاستعلام عن الخادم مع إعدادات الفلتر الحالية. "

#: dnfdragora/helpinfo.py:313
msgid "The dialog also queries automatically when it first opens.<br><br>"
msgstr "يقوم الحوار أيضاً بالاستعلام تلقائياً عند فتحه لأول مرة.<br><br>"

#: dnfdragora/helpinfo.py:314
msgid "<h2>Close button</h2>"
msgstr "<h2>زر الإغلاق</h2>"

#: dnfdragora/helpinfo.py:315
msgid ""
"Press <b>Close</b> (or the window close button) to dismiss the dialog and "
"return to the main window.<br>"
msgstr ""
"اضغط على <b>إغلاق</b> (أو زر إغلاق النافذة) لإغلاق الحوار والعودة إلى النافذة "
"الرئيسية.<br>"

#: dnfdragora/helpinfo.py:324
msgid ""
"The Offline transactions dialog shows the current offline transaction status "
"reported by dnf5daemon.<br><br>"
msgstr ""
"يعرض حوار المعاملات غير المتصلة حالة المعاملة غير المتصلة الحالية التي يبلغ "
"عنها dnf5daemon.<br><br>"

#: dnfdragora/helpinfo.py:326
msgid ""
"Open the dialog from the menu bar: <b>Actions → Offline transactions</b>.<br>"
msgstr "افتح الحوار من شريط القائمة: <b>إجراءات → المعاملات غير المتصلة</b>.<br>"

#: dnfdragora/helpinfo.py:328
msgid "<h2>Status and actions</h2>"
msgstr "<h2>الحالة والإجراءات</h2>"

#: dnfdragora/helpinfo.py:329
msgid ""
"Press <b>Refresh</b> to reload the current offline status. If an offline "
"transaction is pending, you can choose <b>Reboot</b> or <b>Power off</b> and "
"press <b>Finalize</b> to set the finish action, or press <b>Clean</b> to "
"remove the scheduled offline transaction data.<br>"
msgstr ""
"اضغط على <b>تحديث</b> لإعادة تحميل الحالة غير المتصلة الحالية. إذا كانت هناك "
"معاملة غير متصلة معلقة، يمكنك اختيار <b>إعادة تشغيل</b> أو <b>إيقاف التشغيل</"
"b> والضغط على <b>إنهاء</b> لتعيين إجراء الإنهاء، أو الضغط على <b>تنظيف</b> "
"لإزالة بيانات المعاملة غير المتصلة المجدولة.<br>"

#: dnfdragora/helpinfo.py:339
msgid ""
"The System upgrade dialog prepares a distribution upgrade transaction for "
"offline execution at reboot using dnf5daemon.<br><br>"
msgstr ""
"يقوم حوار ترقية النظام بتحضير معاملة ترقية التوزيعة للتنفيذ غير المتصل عند "
"إعادة التشغيل باستخدام dnf5daemon.<br><br>"

#: dnfdragora/helpinfo.py:341
msgid "Open the dialog from the menu bar: <b>Actions → System upgrade</b>.<br>"
msgstr "افتح الحوار من شريط القائمة: <b>إجراءات → ترقية النظام</b>.<br>"

#: dnfdragora/helpinfo.py:342
msgid ""
"<b>Note:</b> this menu is available only on systems where systemd is running."
"<br><br>"
msgstr "<b>ملاحظة:</b> هذه القائمة متاحة فقط على الأنظمة التي يعمل فيها systemd."
"<br><br>"

#: dnfdragora/helpinfo.py:343
msgid "<h2>Safety and confirmation</h2>"
msgstr "<h2>السلامة والتأكيد</h2>"

#: dnfdragora/helpinfo.py:344
msgid ""
"The dialog starts with a warning and keeps advanced options hidden by "
"default. "
msgstr "يبدأ الحوار بتحذير ويبقي الخيارات المتقدمة مخفية بشكل افتراضي. "

#: dnfdragora/helpinfo.py:345
msgid ""
"Enable the acknowledgement checkbox to open the options frame and proceed "
"only if you fully understand the risks.<br><br>"
msgstr ""
"قم بتمكين مربع اختيار الإقرار لفتح إطار الخيارات والمتابعة فقط إذا كنت تفهم "
"المخاطر تماماً.<br><br>"

#: dnfdragora/helpinfo.py:346
msgid "<h2>Releasever option</h2>"
msgstr "<h2>خيار Releasever</h2>"

#: dnfdragora/helpinfo.py:347
msgid ""
"Enter the target <i>releasever</i> exactly as expected by repositories "
"metadata (for example development values such as <i>cauldron</i> or "
"<i>rawhide</i>, where applicable).<br><br>"
msgstr ""
"أدخل <i>releasever</i> الهدف تماماً كما هو متوقع من بيانات المستودعات "
"الوصفية (على سبيل المثال قيم التطوير مثل <i>cauldron</i> أو <i>rawhide</i>، "
"حيثما ينطبق ذلك).<br><br>"

#: dnfdragora/helpinfo.py:348
msgid "<h2>Execution flow</h2>"
msgstr "<h2>سير التنفيذ</h2>"

#: dnfdragora/helpinfo.py:349
msgid ""
"After confirmation, dnfdragora reopens the daemon session with the chosen "
"releasever, prepares system-upgrade in <i>distrosync</i> mode with "
"interactive prompts enabled, resolves dependencies with allow-erasing, then "
"schedules the transaction offline and sets reboot as finish action.<br>"
msgstr ""
"بعد التأكيد، يعيد dnfdragora فتح جلسة الخادم مع releasever المختار، ويحضّر "
"ترقية النظام في وضع <i>مزامنة التوزيعة</i> مع تمكين المطالبات التفاعلية، "
"ويحل الاعتماديات مع السماح بالمسح، ثم يجدول المعاملة غير المتصلة ويضبط إعادة "
"التشغيل كإجراء إنهاء.<br>"

#: dnfdragora/helpinfo.py:358
msgid ""
"The Advisory information dialog queries dnf5daemon advisory metadata and "
"shows matching advisories in a table.<br><br>"
msgstr ""
"يقوم حوار معلومات الاستشارات الأمنية بالاستعلام عن البيانات الوصفية "
"للاستشارات الأمنية لـ dnf5daemon ويعرض الاستشارات الأمنية المتطابقة في "
"جدول.<br><br>"

#: dnfdragora/helpinfo.py:360
msgid ""
"Open the dialog from the menu bar: <b>Actions → Advisory information</b>."
"<br><br>"
msgstr "افتح الحوار من شريط القائمة: <b>إجراءات → معلومات الاستشارات الأمنية</b>."
"<br><br>"

#: dnfdragora/helpinfo.py:362
msgid ""
"Use the filter area to narrow results by availability, advisory IDs, package "
"name patterns, Bugzilla IDs, CVE IDs, advisory types, severities, and "
"toggles for advisories containing CVE/Bugzilla references.<br><br>"
msgstr ""
"استخدم منطقة الفلتر لتضييق النتائج حسب التوفر، ومعرفات الاستشارات الأمنية، "
"وأنماط أسماء الحزم، ومعرفات Bugzilla، ومعرفات CVE، وأنواع الاستشارات "
"الأمنية، والخطورة، ومفاتيح التبديل للاستشارات الأمنية التي تحتوي على مراجع "
"CVE/Bugzilla.<br><br>"

#: dnfdragora/helpinfo.py:364
msgid ""
"The main table shows <b>Advisory ID</b>, <b>Type</b>, <b>Severity</b>, and "
"<b>Title</b> for each advisory returned by the daemon.<br><br>"
msgstr "يعرض الجدول الرئيسي <b>معرف الاستشارة الأمنية</b> و<b>النوع</b> و<b>الخطورة</b> و<b>العنوان</b> لكل استشارة أمنية يعيدها الخادم.<br><br>"

#: dnfdragora/helpinfo.py:365
msgid "<h2>Selected advisory details</h2>"
msgstr "<h2>تفاصيل الاستشارة الأمنية المحددة</h2>"

#: dnfdragora/helpinfo.py:366
msgid ""
"Selecting a row updates the details table with available fields such as "
"vendor, status, description, message, collections, and references.<br><br>"
msgstr "تحديد صف يقوم بتحديث جدول التفاصيل بالحقول المتاحة مثل البائع والحالة والوصف والرسالة والمجموعات والمراجع.<br><br>"

#: dnfdragora/helpinfo.py:367
msgid "<h2>Refresh and Close</h2>"
msgstr "<h2>تحديث وإغلاق</h2>"

#: dnfdragora/helpinfo.py:368
msgid ""
"Press <b>Refresh</b> to run the query with current filters, or <b>Close</b> "
"to dismiss the dialog and return to the main window.<br>"
msgstr "اضغط على <b>تحديث</b> لتشغيل الاستعلام مع الفلاتر الحالية، أو <b>إغلاق</b> لإغلاق الحوار والعودة إلى النافذة الرئيسية.<br>"

