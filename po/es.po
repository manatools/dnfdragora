#: dnfdragora/helpinfo.py:65
msgid ""
"dnfdragora is a DNF frontend, based on Mageia rpmdragora layout and Fedora "
"yumex-dnf interaction with dnfdaemon.<br><br>"
msgstr ""
"dnfdragora es una interfaz para DNF, se basa en  el diseño de rpmdragora de "
"Mageia y la interacción de  yumex-dnf de Fedora con dnfdaemon."

#: dnfdragora/helpinfo.py:66
msgid ""
"dnfdragora is basically a package manager user interface that allows you to "
"install, update, remove, and search for packages and more.<br><br>"
msgstr ""
"básicamente dnfdragora es una interfaz para administrar paquetes que permite "
"instalar, actualizar, eliminar, buscar paquetes y más.<br><br>"

#: dnfdragora/helpinfo.py:67
msgid ""
"dnfdragora is part of manatools and it is based on manatools.aui so that it "
"can work using Qt (PySide6), GTK 4, or ncurses, i.e. both graphical and "
"textual user interfaces.<br><br>"
msgstr ""
"dnfdragora es parte de manatools y esta basada en manatools.aui, por lo que "
"puede utilizar Qt (PySide6), GTK 4, o ncurses, esto es, interfaces gráficas "
"y de texto."

#: dnfdragora/helpinfo.py:68
msgid "dnfdragora window is comprised of:"
msgstr "la ventana de dnfdragora se compone de:"

#: dnfdragora/helpinfo.py:73
msgid "Menu bar content"
msgstr "Contenido de la Barra de Menu"

#: dnfdragora/helpinfo.py:75
msgid "Menu bar contains dnfdragora drop down menus:"
msgstr "La Barra de Menu de dnfdragora contiene menus desplegables:"

#: dnfdragora/helpinfo.py:83
msgid "File Menu"
msgstr "Menu de Archivo"

#: dnfdragora/helpinfo.py:85
msgid "<h2>Reset selection</h2>"
msgstr "<h2>Limpiar selección</h2>"

#: dnfdragora/helpinfo.py:86
msgid ""
"This menu removes any flags on packages; if any packages have been selected "
"for installation or removal, they will be reset to their previous status.<br>"
msgstr ""
"Este menú elimina cualquier marca en los paquetes, si algún paquete se ha "
"seleccionado para instalación o eliminación, regresarán a su estado previo."
"<br>"

#: dnfdragora/helpinfo.py:87
msgid "<h2>Refresh metadata</h2>"
msgstr "<h2>Refrescar metadatos</h2>"

#: dnfdragora/helpinfo.py:88
msgid ""
"This menu sends a request to dnfdaemon to force a refresh of all the "
"metadata. This action is asynchronous and requires rebuilding the package "
"information cache.<br>"
msgstr ""
"Este menu envía una petición a  dnfdaemon para forzar la renovación de todos "
"los metadatos. Esta acción es asíncrona y requiere reconstruir la "
"información del cache de paquetes.<br>"

#: dnfdragora/helpinfo.py:89
msgid "<h2>Repositories</h2>"
msgstr "<h2>Repositorios</h2>"

#: dnfdragora/helpinfo.py:90
msgid "This menu opens the Repository Management dialog.<br>"
msgstr "Este menú abre el diálogo de Manejo de Repositorios.<br>"

#: dnfdragora/helpinfo.py:91
msgid ""
"The dialog lists all configured repositories sorted by name. You can enable "
"or disable each repository using its checkbox. Changes take effect "
"immediately for the current session but are not permanent.<br><br>"
msgstr ""
"Se lista todos los repositorios, ordenados por nombre. Puede activar o "
"desactivar cada repositorio. Los cambios surten efecto de inmediato, pero no "
"son permanentes.<br><br>"

#: dnfdragora/helpinfo.py:92
msgid "<b>Filter frame \\u2014 Show additional repository types</b><br>"
msgstr "<b>Filtrar el marco \\u2014 Muestra repositorios adicionales</b><br>"

#: dnfdragora/helpinfo.py:93
msgid ""
"By default the list hides debug-information, source, and testing "
"repositories. Expand the filter frame by checking its title to show three "
"additional checkboxes:<br>"
msgstr ""
"Por defecto la lista oculta los repositorios debug-information, source, y "
"testing. Expanda el marco del filtro presionando en el título para mostrar "
"tres campos adicionales."

#: dnfdragora/helpinfo.py:94
msgid "<ul>"
msgstr ""

#: dnfdragora/helpinfo.py:95
msgid ""
"<li><b>Debug information</b>: show repositories whose id ends with <i>-"
"debuginfo</i>.</li>"
msgstr ""
"<li><b>Información de Depuración</b>: muestra repositorios cuyo id termina "
"con <i>-debuginfo</i>.</li>"

#: dnfdragora/helpinfo.py:96
msgid ""
"<li><b>Source</b>: show repositories whose id ends with <i>-source</i>.</li>"
msgstr ""
"<li><b>Fuente</b>: muestra repositorios cuyo  id termina en <i>-source</i>.</"
"li>"

#: dnfdragora/helpinfo.py:97
msgid ""
"<li><b>Testing</b>: show repositories whose id contains <i>testing</i>.</li>"
msgstr ""
"<li><b>Testing</b>: muestra repositorios cuyo \n"
" id contiene <i>testing</i>.</li>"

#: dnfdragora/helpinfo.py:98
msgid "</ul>"
msgstr ""

#: dnfdragora/helpinfo.py:99
msgid ""
"If any repository of those types is currently <b>enabled</b> in DNF, the "
"corresponding checkbox is automatically turned on and the frame is expanded, "
"ensuring an active repository is never hidden.<br>"
msgstr ""
"si cualquiera de estos tipos de repositorios esta <b>habilitado</b> en DNF, "
"la caja de comprobación correspondiente estará marcada y el marco se "
"expandirá, asegurando que un repositorio activo no sea ocultado.<br>"

#: dnfdragora/helpinfo.py:100
msgid ""
"The filter selections are saved in the user configuration file and restored "
"at the next launch.<br>"
msgstr ""
"Las opciones de filtrado se guardan para cada usuario y se restauran en la "
"siguiente ejecución.<br>"

#: dnfdragora/helpinfo.py:101
msgid "<h2>Quit</h2>"
msgstr "<h2>Salir</h2>"

#: dnfdragora/helpinfo.py:102
msgid "This menu exits from dnfdragora.<br>"
msgstr "Este menú sale de dnfdragora.<br>"

#: dnfdragora/helpinfo.py:109
msgid "Information Menu"
msgstr "Menú de información"

#: dnfdragora/helpinfo.py:111
msgid "<h2>History</h2>"
msgstr "<h2>Historial</h2>"

#: dnfdragora/helpinfo.py:112
msgid ""
"This menu runs a dialog containing transaction history shown in a tree "
"ordered by date. Selected history can be undone by pressing <b>Undo</b> "
"button.<br>"
msgstr ""
"Este menú ejecuta un cuadro de diálogo que contiene el historial de "
"transacciones que se muestra en un árbol ordenado por fecha. El historial "
"seleccionado se puede deshacer presionando el botón <b>Deshacer</b>.<br>"

#: dnfdragora/helpinfo.py:113
msgid ""
"<br><i>Note that this function is currently broken because of a DNF API "
"change</i><br>"
msgstr ""
"<br><i>Tenga en cuenta que esta función está actualmente rota debido a un "
"cambio en el API de DNF</i><br>"

#: dnfdragora/helpinfo.py:120
msgid "Option Menu"
msgstr "Menú opciones"

#: dnfdragora/helpinfo.py:122
msgid "<h2>User preferences</h2>"
msgstr "<h2>Preferencias de usuario</h2>"

#: dnfdragora/helpinfo.py:123
#, python-format
msgid ""
"This menu opens a %s containing user settings to customize dnfdragora "
"behavior.<br>"
msgstr ""
"Este menú abre un %s que contiene la configuración de usuario para "
"personalizar el comportamiento de dnfdragora.<br>"

#: dnfdragora/helpinfo.py:123
msgid "dialog"
msgstr "diálogo"

#: dnfdragora/helpinfo.py:131
msgid ""
"This dialog allows to customize dnfdragora behavior by changing options. "
"Some changes are available after closing the dialog, others need a "
"dnfdragora restart.<br><br>"
msgstr ""
"Este diálogo permite personalizar el comportamiento de dnfdragora cambiando "
"las opciones. Algunos cambios están disponibles después de cerrar el "
"diálogo, y otros necesitan reiniciar dnfdragora.<br><br>"

#: dnfdragora/helpinfo.py:132
msgid "<h2>System options</h2>"
msgstr "<h2>Opciones de Sistema</h2>"

#: dnfdragora/helpinfo.py:133
msgid ""
"<ul><li><b>Run transactions on packages automatically without confirmation "
"needed</b>: if checked transactions do not need to be confirmed, dnfdragora "
"works as answering always <i>yes</i>."
msgstr ""
"<ul><li><b>Ejecutar transacciones de paquetes automáticamente sin necesidad "
"de confirmación</b>: si se ha marcado, las transacciones no se confirmará, "
"pues dnfdragor funcionará como si siempre se respondiera <i>sí</i>."

#: dnfdragora/helpinfo.py:134
msgid ""
"<br><b>NOTE</b> that this option means that also removing packages is "
"silently accepted</li>"
msgstr ""
"<br><b>NOTA</b>: esta opción también significa que se eliminarán paquetes "
"silenciosamente </li>"

#: dnfdragora/helpinfo.py:135
msgid ""
"<li><b>Consider packages to upgrade as updates</b>: if checked upgrades are "
"added to updates and filtered as updates.</li>"
msgstr ""
"<li><b>Considerar nuevas versiones como actualizaciones</b>: al activar, las "
"nuevas versiones son presentadas como actualizaciones.</li>"

#: dnfdragora/helpinfo.py:136
msgid ""
"<li><b>Hide dnfdragora-update menu if there are no updates</b>: if checked "
"dnfdragora update is hidden if there are no updates."
msgstr ""
"<li><b>Esconder el menú de dnfdragora-update si no hay actualizaciones</b>: "
"al activar, si no hay actualizaciones, se esconde dnfdragora-update."

#: dnfdragora/helpinfo.py:137
msgid ""
"<br><b>NOTE</b> that this option is experimental, not all desktops manage it "
"as expected</li>"
msgstr ""
"<br><b>NOTA</b> la opción es experimental, no en todos los escritorios se "
"comporta como se espera</li>"

#: dnfdragora/helpinfo.py:138
msgid ""
"<li><b>Interval to check for updates</b>: the given number represents how "
"often dnfdragora checks for updates; the value is expressed in minutes</li>"
msgstr ""
"<li><b>Intervalo para buscar actualizaciones</b>: el número dado representa "
"la frecuencia con la que dnfdragora buscara actualizaciones. El valor se "
"expresa en minutos.</li>"

#: dnfdragora/helpinfo.py:139
msgid ""
"<li><b>Metadata expire time</b>: time to force Metadata expiration, the "
"value is expressed in hours</li></ul>"
msgstr ""
"<li><b>Tiempo de expiración de metadatos</b>: tiempo para forzar la "
"caducidad de los metadatos. El valor se expresa en horas.</li></ul>"

#: dnfdragora/helpinfo.py:140
msgid "<h2>Layout options</h2>"
msgstr "<h2>Opciones de diseño</h2>"

#: dnfdragora/helpinfo.py:141
msgid ""
"<ul><li><b>Show updates</b>: if checked dnfdragora starts with <i>updates</"
"i> filter active, i.e. showing only package available for updates if any.</"
"li>"
msgstr ""
"<ul><li><b>Mostrar actualizaciones</b>: si está marcada, dnfdragora comienza "
"con el filtro <i>actualizaciones</i> activo, es decir, muestra solo paquetes "
"con actualizaciones disponibles, si hay alguno.</li>"

#: dnfdragora/helpinfo.py:142
msgid ""
"<li><b>Do not show groups view</b>: filtering by groups could require CPU if "
"using comps, if this option is checked dnfdragora starts showing all "
"packages.</li></ul>"
msgstr ""
"<li><b>No mostrar vista de grupos</b>: el filtrado por grupos podría "
"requerir CPU si se usan comps. Si esta opción está marcada, dnfdragora "
"comienza mostrando todos los paquetes.</li></ul>"

#: dnfdragora/helpinfo.py:143
msgid "<b>NOTE</b> that the above options require dnfdragora to be restarted."
msgstr ""
"<b>NOTA</b>: las opciones anteriores requieren que se reinicie dnfdragora."

#: dnfdragora/helpinfo.py:144
msgid "<h2>Logging options</h2>"
msgstr "<h2>Opciones de Registro</h2>"

#: dnfdragora/helpinfo.py:145
msgid ""
"Enable these options to let dnfdragora log on file called <i>dnfdragora.log</"
"i>."
msgstr ""
"Habilite esta opción para permitir que dnfdragora escriba sus registros en "
"un archivo llamado <i>dnfdragora.log</i>."

#: dnfdragora/helpinfo.py:146
msgid ""
"<ul><li><b>Change directory</b>: this option allows you to set the logging "
"directory; the directory must exist and needs write permission.</li>"
msgstr ""
"<ul><li><b>Cambiar directorio</b>: esta opción permite cambiar el directorio "
"del archivo de registro, el directorio debe existir y tener permisos de "
"escritura.</li>"

#: dnfdragora/helpinfo.py:147
msgid ""
"<li><b>Debug level</b>: if checked, verbose logging is enabled.</li></ul>"
msgstr ""
"<li><b>Nivel de Depuración</b>: si se marca, se activará un registro más "
"extenso.</li></ul>"

#: dnfdragora/helpinfo.py:155
msgid "Help Menu"
msgstr "Menú de Ayuda"

#: dnfdragora/helpinfo.py:157
msgid "<h2>Manual</h2>"
msgstr "<h2>Manual</h2>"

#: dnfdragora/helpinfo.py:158
msgid "This menu opens dnfdragora help dialog."
msgstr "Este menú abre el dialogo de ayuda de dnfdragora."

#: dnfdragora/helpinfo.py:159
msgid "<h2>About</h2>"
msgstr "<h2>Acerca de</h2>"

#: dnfdragora/helpinfo.py:160
msgid "This menu opens dnfdragora about dialog."
msgstr "Este menú abre el dialogo de información sobre dnfdragora."

#: dnfdragora/helpinfo.py:170
msgid "<h2>Views</h2>"
msgstr "<h2>Vistas</h2>"

#: dnfdragora/helpinfo.py:171
msgid ""
"The first combobox allows you to show packages by groups. If <i>Groups</i> "
"is selected, the group panel shows a tree view containing groups, and "
"selecting a group shows related packages in the package panel.<br>"
msgstr ""
"El primer cuadro combinado permite mostrar paquetes por grupos. Si "
"selecciona <i>Grupos</i>, el panel de grupos muestra los grupos en una vista "
"de árbol, y al seleccionar un grupo se muestran los paquetes relacionados en "
"el panel paquetes.<br>"

#: dnfdragora/helpinfo.py:172
msgid ""
"If <i>All</i> is selected, the package panel contains all the packages.<br>"
msgstr ""
"Sí se selecciona <i>Todos</i>, el panel paquetes contiene todos los paquetes."
"<br>"

#: dnfdragora/helpinfo.py:173
msgid "<h2>Filters</h2>"
msgstr "<h2>Filtros</h2>"

#: dnfdragora/helpinfo.py:174
msgid ""
"The Filter combobox allows you to filter the packages shown in the package "
"panel by:"
msgstr ""
"El cuadro combinado Filtros permite mostrar los paquetes en el panel de "
"paquetes por:"

#: dnfdragora/helpinfo.py:176
msgid "<li><b>Installed</b>: shows installed packages only.</li>"
msgstr "<li><b>Instalados</b>: muestra solo paquetes instalados.</li>"

#: dnfdragora/helpinfo.py:177
msgid "<li><b>Not installed</b>: shows available packages only.</li>"
msgstr "<li><b>No Instalados</b>: muestra solo los paquetes disponibles.</li>"

#: dnfdragora/helpinfo.py:178
msgid ""
"<li><b>To update</b>: shows packages that are available for updates only.</"
"li>"
msgstr ""
"<li><b>Para actualizar</b>: muestra solo los paquetes disponibles para "
"actualizar.</li>"

#: dnfdragora/helpinfo.py:179
msgid ""
"<li><b>Show x86_64 and noarch only</b>: if dnfdragora is running on x86_64 "
"architecture, it hides i686 packages.</li>"
msgstr ""
"<li><b>Mostrar solo x86_64 y noarch</b>: si dnfdragora se esta ejecutando en "
"un sistema x86_64 , los paquetes i686 serán ocultados.</li>"

#: dnfdragora/helpinfo.py:180
msgid ""
"<li><b>All</b>: shows all the packages, i.e. available, updates and "
"installed.</li>"
msgstr ""
"<li><b>Todos</b>: muestra todos los paquetes: disponibles, actualizaciones e "
"instalados.</li>"

#: dnfdragora/helpinfo.py:182
msgid "<h2>Search</h2>"
msgstr "<h2>Buscar</h2>"

#: dnfdragora/helpinfo.py:183
#, python-format
msgid "Pressing the <b>Search</b> button (magnifier icon) opens the %s "
msgstr "Presionar el botón <b>Buscar</b>  (icono de lupa) abre el %s "

#: dnfdragora/helpinfo.py:184
msgid ""
"that provides full-featured package search. When a search is active the "
"filter combobox is disabled "
msgstr ""
"que proporciona una búsqueda de paquetes repleta de características. Cuando "
"una búsqueda está activa la caja de filtros se desactiva "

#: dnfdragora/helpinfo.py:185
msgid "and an info label shows the active search text or dependency query. "
msgstr "y una etiqueta de información muestra el texto o dependencia buscados."

#: dnfdragora/helpinfo.py:186
msgid ""
"The <b>Clear search</b> button (eraser icon) next to the Search button "
"resets all search state "
msgstr ""
"El botón <b>Limpiar búsqueda</b> (icono de borrador) junto al botón de "
"Búsqueda deshace cualquier estado de búsqueda "

#: dnfdragora/helpinfo.py:187
msgid "and re-enables the filter combobox.<br>"
msgstr "y activa el cuadro de filtros.<br>"

#: dnfdragora/helpinfo.py:197
msgid ""
"This panel shows all the groups available to filter packages, if the Groups "
"view is selected. The special group <i>Search</i> is added after a search is "
"performed."
msgstr ""
"Este panel muestra todos los grupos disponibles para filtrar paquetes, al "
"seleccionar la vista Grupos. El grupo especial <i>Búsqueda</i> se añade al "
"realizar una búsqueda."

#: dnfdragora/helpinfo.py:207
msgid ""
"This panel shows all the filtered packages with their basic information such "
"as <i>name</i>, <i>summary</i>, <i>version</i>, <i>release</i>, "
"<i>architecture</i>, <i>size</i>, and <i>status</i>."
msgstr ""
"Este panel muestra todos los paquetes filtrados con su información básica "
"como <i>nombre</i>, <i>resumen</i>, <i>versión</i>, <i>#publicación·</i>, "
"<i>arquitectura</i>, <i>tamaño</i>, y <i>estado</i>."

#: dnfdragora/helpinfo.py:208
msgid ""
"A checkbox for any packages is available to add related package to "
"transaction for installing, updating or removing."
msgstr ""
"En cualquier paquete esta disponible una casilla que añade ese paquete a una "
"transacción para instalar, actualizar o eliminar."

#: dnfdragora/helpinfo.py:218
msgid ""
"This panel shows all the package information such as <i>description</i>, "
"<i>URL</i>, <i>repository</i>, <i>requirements</i>, <i>file list</i>, and "
"<i>changelog</i>."
msgstr ""
"Este panel muestra toda la información de un paquete, como <i>descripcion</"
"i>, <i>URL</i>, <i>repositorio</i>, <i>dependencias</i>, <i>lista de "
"archivos</i>, y <i>cambios</i>."

#: dnfdragora/helpinfo.py:219
msgid ""
"<br><br><i>Note that changelog is not provided by dnfdaemon at the moment.</"
"i>"
msgstr ""
"<br><br><i>Note que la información sobre cambios por el momento no es "
"proporcionada por dnfdaemon.</i>"

#: dnfdragora/helpinfo.py:227
msgid "Progress bar"
msgstr "Barra de Progreso"

#: dnfdragora/helpinfo.py:229
msgid ""
"Progress bar shows dnfdragora operations progression such as transactions "
"and caching data."
msgstr ""
"La barra de Progreso muestra las operaciones en progreso de  dnfdragora, "
"tales como transacciones y obtención de datos."

#: dnfdragora/helpinfo.py:237
msgid "Buttons line"
msgstr "Linea de botones"

#: dnfdragora/helpinfo.py:239
msgid ""
"<ul><li><b>Apply</b>: when some packages are selected for installing or "
"updating or deselected for uninstalling this button runs the transaction to "
"be performed.</li>"
msgstr ""
"<ul><li><b>Aplicar</b>: cuando algun(os) paquetes están seleccionados para "
"instalarse o actualizarse ó deseleccionados para desinstalarse este botón "
"ejecuta la transacción correspondiente.</li>"

#: dnfdragora/helpinfo.py:240
msgid ""
"<li><b>Select all</b>: if packages are filtered for updates only this button "
"allows to select all the packages in one shot.</li>"
msgstr ""
"<li><b>Seleccionar todo</b>: si los paquetes se filtran para actualizar, "
"este botón permite seleccionar todos los paquetes.</li>"

#: dnfdragora/helpinfo.py:241
msgid "<li><b>Quit</b>: exits from dnfdragora.</li></ul>"
msgstr "<li><b>Salir</b>: sale de dnfdragora.</li></ul>"

