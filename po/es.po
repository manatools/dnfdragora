msgid "&Binaries"
msgstr "&Binarios"

#: dnfdragora/dialogs.py:1561
msgid ""
"Restrict file matching to /usr/bin and /usr/sbin only (subset of Files)."
msgstr ""
"Restringir solamente a archivos en /usr/bin y /usr/sbin  (subconjunto de "
"Archivos)."

