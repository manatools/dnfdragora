#: share/metainfo/org.mageia.dnfdragora.metainfo.xml:7
msgid "dnfdragora"
msgstr "dnfdragora"

#: share/metainfo/org.mageia.dnfdragora.metainfo.xml:9
msgid "ManaTools"
msgstr "ManaTools"

#: share/metainfo/org.mageia.dnfdragora.metainfo.xml:11
msgid "A frontend for DNF using libyui UI abstraction library"
msgstr ""
"Una interfície gràfica per a DNF mitjançant la biblioteca d'abstracció "
"d'interfície d'usuari libyui"

#: share/metainfo/org.mageia.dnfdragora.metainfo.xml:13
msgid ""
"dnfdragora is a DNF frontend, inspired by rpmdragora from Mageia (originally "
"rpmdrake)."
msgstr ""
"dnfdragora és una interfície gràfica de DNF, que està inspirada amb "
"rpmdragora de Mageia (rpmdrake originàriament)."

#: share/metainfo/org.mageia.dnfdragora.metainfo.xml:17
msgid ""
"dnfdragora is written in Python 3 and uses manatools AUI, the widget "
"abstraction library written for manatools applications based on the libYUI "
"experience, so that it can be run using Qt 6 (pySide), GTK 4, or ncurses "
"interfaces. It provides a frontend for the DNF package manager, using DNF 5 "
"daemon, that can be used in any kind of system environment."
msgstr ""
"El dnfdragora està escrit en Python 3 i usa manatools AUI, la biblioteca "
"d'abstracció de ginys escrita per a aplicacions de manatools basada en "
"l'experiència libYUI, de manera que es pot executar usant interfícies de Qt "
"6 (pySide), GTK 4 o ncurses. Proporciona una aplicació frontal per al gestor "
"de paquets DNF, amb el dimoni DNF 5, que es pot usar en qualsevol tipus "
"d'entorn de sistema."

#: share/metainfo/org.mageia.dnfdragora.metainfo.xml:26
msgid "Main window"
msgstr "Finestra principal"

