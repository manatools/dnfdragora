#: dnfdragora/ui.py:324
msgid ""
"dnfdragora is a DNF5 daemon frontend that works using GTK, ncurses and QT"
msgstr ""
"La dnfdragora és una aplicació frontal del dimoni de DNF5 que funciona amb "
"GTK, ncurses i QT."

#: dnfdragora/ui.py:326
msgid "Developers"
msgstr "Desenvolupadors"

#: dnfdragora/ui.py:332
msgid "Current developers and maintainers"
msgstr "Desenvolupadors i mantenidors actuals"

#: dnfdragora/ui.py:338
msgid "Translations"
msgstr "Traduccions"

#: dnfdragora/ui.py:342
msgid "Contributors"
msgstr "Col·laboradors"

#: dnfdragora/ui.py:351
msgid "Project Links"
msgstr "Enllaços de projectes"

#: dnfdragora/ui.py:356
msgid "Report Issues or Improvements"
msgstr "Informar de problemes o millores"

#: dnfdragora/ui.py:374
msgid "Logging directory not found"
msgstr "No s'ha trobat el directori de registre."

#: dnfdragora/ui.py:376
#, python-format
