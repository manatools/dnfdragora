#: dnfdragora/dialogs.py:1532
msgid "Find:"
msgstr "Encontrar:"

#: dnfdragora/dialogs.py:1540
msgid ""
"Enter the search pattern. In text mode: words separated by spaces or commas. "
"In dependency query mode: capability name (e.g. 'python3', '/usr/bin/"
"python3')."
msgstr ""
"Insira o padrão de pesquisa. No modo de texto: palavras separadas por "
"espaços ou vírgulas. No modo de consulta de dependência: nome da capacidade "
"(por exemplo, 'python3', '/usr/bin/python3')."

#: dnfdragora/dialogs.py:1547
msgid "Search in:"
msgstr "Pesquisar em:"

#: dnfdragora/dialogs.py:1548
msgid "N&ames"
msgstr "N&omes"

#: dnfdragora/dialogs.py:1550
msgid "Search in package names and NEVRA (name-epoch:version-release.arch)."
msgstr ""
"Pesquisar em nomes de pacotes e NEVRA (nome-época:versão-lançamento."
"arquitetura)."

#: dnfdragora/dialogs.py:1551
msgid "&Provides"
msgstr "&Fornecedores"

#: dnfdragora/dialogs.py:1553
msgid "Also match packages whose Provides: tags include the search pattern."
msgstr ""
"Também incluir pacotes cujas tags Fornecedores: incluam o padrão de pesquisa."

#: dnfdragora/dialogs.py:1554
msgid "&Files"
msgstr "&Arquivos"

#: dnfdragora/dialogs.py:1556
msgid "Match packages that own files whose path matches the pattern."
msgstr ""
"Identificar pacotes que possuam arquivos cujo caminho corresponda ao padrão."

#: dnfdragora/dialogs.py:1559
msgid "&Binaries"
msgstr "&Binários"

#: dnfdragora/dialogs.py:1561
msgid ""
"Restrict file matching to /usr/bin and /usr/sbin only (subset of Files)."
msgstr ""
"Restringir a correspondência de arquivos apenas a /usr/bin e /usr/sbin "
"(subconjunto de arquivos)."

#: dnfdragora/dialogs.py:1562
msgid "S&ources"
msgstr "F&ontes"

#: dnfdragora/dialogs.py:1564
msgid "Include source RPMs (*.src.rpm) in the results."
msgstr "Incluir os RPMs fontes (*.src.rpm) nos resultados."

#: dnfdragora/dialogs.py:1566
msgid "Su&mmary"
msgstr "Re&sumo"

#: dnfdragora/dialogs.py:1568
msgid "Search in package summaries. Only available in regexp mode."
msgstr ""
"Pesquisar em resumos de pacotes. Disponível apenas no modo de expressão "
"regular."

#: dnfdragora/dialogs.py:1572
msgid "Scope:"
msgstr "Escopo:"

#: dnfdragora/dialogs.py:1583
msgid ""
"Limit the search to a subset of packages: all, installed, available to "
"install, upgrades or upgradable."
msgstr ""
"Limitar a pesquisa a um subconjunto de pacotes: todos, instalados, "
"disponíveis para instalação, atualizações ou atualizáveis."

#: dnfdragora/dialogs.py:1585
msgid "Use &regexp"
msgstr "Usar &expressões regulares"

#: dnfdragora/dialogs.py:1588
msgid ""
"Treat the Find field as a regular expression (Python re syntax). Disables "
"multi-field search."
msgstr ""
"Tratar o campo \"Localizar\" como uma expressão regular (sintaxe `re` do "
"Python). Desativa a busca em múltiplos campos."

#: dnfdragora/dialogs.py:1590
msgid "&Latest only"
msgstr "&Somente as versões mais recentes"

#: dnfdragora/dialogs.py:1592
msgid "Show only the latest version of each package name."
msgstr "Exibir apenas a versão mais recente de cada pacote."

#: dnfdragora/dialogs.py:1593
msgid "Fu&zzy search"
msgstr "Bus&ca aproximada"

#: dnfdragora/dialogs.py:1595
msgid ""
"Automatically add wildcards around each search token (e.g. 'gtk' becomes "
"'*gtk*'). Disabled in regexp mode."
msgstr ""
"Adiciona automaticamente caracteres curinga em torno de cada token de "
"pesquisa (por exemplo, 'gtk' torna-se '*gtk*'). Desativado no modo de "
"expressão regular."

#: dnfdragora/dialogs.py:1596
msgid "Case &sensitive"
msgstr "Maiúsculas e &minúsculas"

#: dnfdragora/dialogs.py:1599
msgid ""
"When checked, the search is case-sensitive. By default search is case-"
"insensitive."
msgstr ""
"Quando selecionada, a pesquisa diferencia maiúsculas de minúsculas. Por "
"padrão, a pesquisa não diferencia maiúsculas de minúsculas."

