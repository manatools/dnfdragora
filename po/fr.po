#: dnfdragora/helpinfo.py:124
#, python-format
msgid ""
"This menu opens a %s containing user settings to customize dnfdragora "
"behavior.<br>"
msgstr ""
"Ce menu ouvre une %s contenant les préférences utilisateur pour "
"personnaliser le comportement de dnfdragora.<br>"

#: dnfdragora/helpinfo.py:124
msgid "dialog"
msgstr "boîte de dialogue"

#: dnfdragora/helpinfo.py:132
msgid ""
"This dialog allows to customize dnfdragora behavior by changing options. "
"Some changes are available after closing the dialog, others need a "
"dnfdragora restart.<br><br>"
msgstr ""
"Cette boîte de dialogue permet la personnalisation du comportement de "
"dnfdragora en changeant les options. Certains changements sont immédiatement "
"activés, d'autres nécessitent de redémarrer dnfdragora.<br><br>"

#: dnfdragora/helpinfo.py:133
msgid "<h2>System options</h2>"
msgstr "<h2>Options Système</h2>"

#: dnfdragora/helpinfo.py:134
msgid ""
"<ul><li><b>Run transactions on packages automatically without confirmation "
"needed</b>: if checked transactions do not need to be confirmed, dnfdragora "
"works as answering always <i>yes</i>."
msgstr ""
"<ul><li><b>Exécuter les transactions sur les paquetages automatiquement sans "
"nécessiter de confirmation de la part de l'utilisateur.</b> : si coché, les "
"transactions s'exécutent sans nécessiter de confirmation, dnfdragora "
"fonctionne comme si toutes les questions étaient répondues <i>Oui</i>. "

#: dnfdragora/helpinfo.py:135
msgid ""
"<br><b>NOTE</b> that this option means that also removing packages is "
"silently accepted</li>"
msgstr ""
"<br><b>Remarque importante</b> : la suppression de paquets sera acceptée "
"afin de satisfaire les dépendances.</li>"

#: dnfdragora/helpinfo.py:136
msgid ""
"<li><b>Consider packages to upgrade as updates</b>: if checked upgrades are "
"added to updates and filtered as updates.</li>"
msgstr ""
"<li><b>Considérer les paquets à mettre à niveau comme des mises à jour</"
"b>\\: si les mises à niveau cochées sont ajoutées comme mises à jour et "
"filtrées en tant que mises à jour.</li> "

#: dnfdragora/helpinfo.py:137
msgid ""
"<li><b>Hide dnfdragora-update menu if there are no updates</b>: if checked "
"dnfdragora update is hidden if there are no updates."
msgstr ""
"<li><b>Cacher le menu de mise à jour de dnfdragora s'il n'y a pas de mises à "
"jour</b>: si la vérification de  mise à jour de dnfdragora elle-même est "
"cachée quand il n'y a pas de mises à jour. "

#: dnfdragora/helpinfo.py:138
msgid ""
"<br><b>NOTE</b> that this option is experimental, not all desktops manage it "
"as expected</li>"
msgstr ""
"<br><b>NOTEz</b> que cette option est expérimentale, tous les bureaux ne "
"l'utilisent pas comme espéré</li> "

#: dnfdragora/helpinfo.py:139
msgid ""
"<li><b>Interval to check for updates</b>: the given number represents how "
"often dnfdragora checks for updates; the value is expressed in minutes</li>"
msgstr ""
"<li><b>Intervalle de vérification des mises à jour</b>: le nombre indiqué "
"représente la fréquence à laquelle dnfdragora vérifie la présence de mises à "
"jour : la valeur s'exprime en minutes</li> "

#: dnfdragora/helpinfo.py:140
msgid ""
"<li><b>Metadata expire time</b>: time to force Metadata expiration, the "
"value is expressed in hours</li></ul>"
msgstr ""
"<li><b>Durée avant expiration des métadonnées</b> : temps, en heures, avant "
"que les métadonnées seront considérées trop anciennes.</li></ul>"

#: dnfdragora/helpinfo.py:141
msgid "<h2>Layout options</h2>"
msgstr "<h2>Options de mise en forme</h2>"

#: dnfdragora/helpinfo.py:142
msgid ""
"<ul><li><b>Show updates</b>: if checked dnfdragora starts with <i>updates</"
"i> filter active, i.e. showing only package available for updates if any.</"
"li>"
msgstr ""
"<ul><li><b>Montrer les mises à jour</b> : si coché, dnfdragora commence avec "
"le filtre de <i>mises à jour</i> actif, c'est-à-dire ne montrant que les "
"paquets disponibles pour les mises à jour, le cas échéant."

#: dnfdragora/helpinfo.py:143
msgid ""
"<li><b>Do not show groups view</b>: filtering by groups could require CPU if "
"using comps, if this option is checked dnfdragora starts showing all "
"packages.</li></ul>"
msgstr ""
"<li><b>Ne pas afficher la vue des groupes</b> : le filtrage par groupes peut "
"nécessiter du temps processeur si vous utilisez des comps, si cette option "
"est cochée, dnfdragora commence à afficher tous les paquetages.</li></ul>"

#: dnfdragora/helpinfo.py:144
msgid "<b>NOTE</b> that the above options require dnfdragora to be restarted."
msgstr ""
"<b>Remarque</b> : les options ci-dessus requièrent le redémarrage de "
"dnfdragora."

#: dnfdragora/helpinfo.py:145
msgid "<h2>Logging options</h2>"
msgstr "<h2>Options de journalisation</h2>"

#: dnfdragora/helpinfo.py:146
msgid ""
"Enable these options to let dnfdragora log on file called <i>dnfdragora.log</"
"i>."
msgstr ""
"Activer cette option permet à dnfdragora de journaliser ses actions dans le "
"fichier <i>dnfdragora.log</i>."

#: dnfdragora/helpinfo.py:147
msgid ""
"<ul><li><b>Change directory</b>: this option allows you to set the logging "
"directory; the directory must exist and needs write permission.</li>"
msgstr ""
"<ul><li><b>Changer de dossier</b>: cette option permet de choisir le dossier "
"pour la journalisation ; le dossier doit exister et avoir une autorisation "
"d'écriture.</li> "

#: dnfdragora/helpinfo.py:148
msgid ""
"<li><b>Debug level</b>: if checked, verbose logging is enabled.</li></ul>"
msgstr ""
"<li><b>Niveau de déboggage</b>: si c'est coché, une journalisation est "
"activée</li></ul> "

#: dnfdragora/helpinfo.py:156
msgid "Help Menu"
msgstr "Menu Aide"

#: dnfdragora/helpinfo.py:158
msgid "<h2>Manual</h2>"
msgstr "<h2>Manuel</h2>"

#: dnfdragora/helpinfo.py:159
msgid "This menu opens dnfdragora help dialog."
msgstr "Ce menu ouvre l'Aide de dnfdragora."

#: dnfdragora/helpinfo.py:160
msgid "<h2>About</h2>"
msgstr "<h2>A propos</h2>"

#: dnfdragora/helpinfo.py:161
msgid "This menu opens dnfdragora about dialog."
msgstr "Ce menu ouvre la boîte de dialogue A propos de dnfdragora."

#: dnfdragora/helpinfo.py:171
msgid "<h2>Views</h2>"
msgstr "<h2>Vues</h2>"

#: dnfdragora/helpinfo.py:172
msgid ""
"The first combobox allows you to show packages by groups. If <i>Groups</i> "
"is selected, the group panel shows a tree view containing groups, and "
"selecting a group shows related packages in the package panel.<br>"
msgstr ""

#: dnfdragora/helpinfo.py:173
msgid ""
"If <i>All</i> is selected, the package panel contains all the packages.<br>"
msgstr ""

#: dnfdragora/helpinfo.py:174 dnfdragora/helpinfo.py:256
msgid "<h2>Filters</h2>"
msgstr "<h2>Filtres</h2>"

#: dnfdragora/helpinfo.py:175
msgid ""
"The Filter combobox allows you to filter the packages shown in the package "
"panel by:"
msgstr ""
"Le menu déroulant de filtres permet de filtrer les paquets apparaissant dans "
"le panneau de paquets par:"

#: dnfdragora/helpinfo.py:177
msgid "<li><b>Installed</b>: shows installed packages only.</li>"
msgstr ""

#: dnfdragora/helpinfo.py:178
msgid "<li><b>Not installed</b>: shows available packages only.</li>"
msgstr ""
"<li><b>Non installés</b> : montre les paquetages disponible à l'installation "
"uniquement.</li>"

#: dnfdragora/helpinfo.py:179
msgid ""
"<li><b>To update</b>: shows packages that are available for updates only.</"
"li>"
msgstr ""
"<li><b>Mise à jour possible</b> : montre les paquetages disponibles à la "
"mise à jour uniquement.</li>"

#: dnfdragora/helpinfo.py:180
msgid ""
"<li><b>Show x86_64 and noarch only</b>: if dnfdragora is running on x86_64 "
"architecture, it hides i686 packages.</li>"
msgstr ""
"<li><b>Montre uniquement les paquetages x86_64 et noarch</b> : si dnfdragora "
"s'exécute sur une architecture x86_64, ceci masque les paquetages i686.</li>"

#: dnfdragora/helpinfo.py:181
msgid ""
"<li><b>All</b>: shows all the packages, i.e. available, updates and "
"installed.</li>"
msgstr ""

#: dnfdragora/helpinfo.py:183
msgid "<h2>Search</h2>"
msgstr "<h2>Recherche</h2>"

#: dnfdragora/helpinfo.py:184
#, python-format
msgid "Pressing the <b>Search</b> button (magnifier icon) opens the %s "
msgstr ""

#: dnfdragora/helpinfo.py:185
msgid ""
"that provides full-featured package search. When a search is active the "
"filter combobox is disabled "
msgstr ""

#: dnfdragora/helpinfo.py:186
msgid "and an info label shows the active search text or dependency query. "
msgstr ""

#: dnfdragora/helpinfo.py:187
msgid ""
"The <b>Clear search</b> button (eraser icon) next to the Search button "
"resets all search state "
msgstr ""

#: dnfdragora/helpinfo.py:188
msgid "and re-enables the filter combobox.<br>"
msgstr ""

#: dnfdragora/helpinfo.py:198
msgid ""
"This panel shows all the groups available to filter packages, if the Groups "
"view is selected. The special group <i>Search</i> is added after a search is "
"performed."
msgstr ""
"Ce panneau affiche tous les groupes disponibles pour filtrer les paquets, si "
"la vue des Groupes a été sélectionnée. La <i>Recherche</i> spéciale par "
"groupe est ajoutée après qu'une recherche est effectuée."

#: dnfdragora/helpinfo.py:208
msgid ""
"This panel shows all the filtered packages with their basic information such "
"as <i>name</i>, <i>summary</i>, <i>version</i>, <i>release</i>, "
"<i>architecture</i>, <i>size</i>, and <i>status</i>."
msgstr ""
"Ce panneau affiche tous les paquets filtrés avec les informations basiques "
"telles que <i>nom</i>, <i>résumé</i>, <i>version</i>, <i>rpublication "
"(release)</i>, <i>architecture</i>, <i>taille</i>, et <i>statut</i>. "

#: dnfdragora/helpinfo.py:209
msgid ""
"A checkbox for any packages is available to add related package to "
"transaction for installing, updating or removing."
msgstr ""
"Une case à cocher est disponible pour ajouter les dépendances au paquet à la "
"transaction à installer, mettre à jour ou supprimer."

#: dnfdragora/helpinfo.py:219
msgid ""
"This panel shows all the package information such as <i>description</i>, "
"<i>URL</i>, <i>repository</i>, <i>requirements</i>, <i>file list</i>, and "
"<i>changelog</i>."
msgstr ""
"Ce panneau affiche toutes les informations du paquet telles que la "
"<i>description</i>, l'<i>URL</i>, le <i>dépôt</i>, les <i>exigences</i>, la "
"<i>liste des fichiers</i> et le <i>journal des modifications</i>."

#: dnfdragora/helpinfo.py:220
msgid ""
"<br><br><i>Note that changelog is not provided by dnfdaemon at the moment.</"
"i>"
msgstr ""
"<br><br><i>Notez que le journal des modifications n'est pas fourni par "
"dnfdaemon pour le moment.</i>"

#: dnfdragora/helpinfo.py:228
msgid "Progress bar"
msgstr "Barre de progression"

#: dnfdragora/helpinfo.py:230
msgid ""
"Progress bar shows dnfdragora operations progression such as transactions "
"and caching data."
msgstr ""
"La barre de progression montre la progression des opérations dans dnfdragora "
"telles que les transactions et la mise en cache des données."

#: dnfdragora/helpinfo.py:238
msgid "Buttons line"
msgstr "Ligne de boutons"

#: dnfdragora/helpinfo.py:240
msgid ""
"<ul><li><b>Apply</b>: when some packages are selected for installing or "
"updating or deselected for uninstalling this button runs the transaction to "
"be performed.</li>"
msgstr ""
"<ul><li><b>Appliquer</b> : lorsque certains paquetages sont sélectionnés "
"pour l'installation ou la mise à jour ou désélectionnés pour la "
"désinstallation, ce bouton exécute la transaction à effectuer.</li>"

#: dnfdragora/helpinfo.py:241
msgid ""
"<li><b>Select all</b>: if packages are filtered for updates only this button "
"allows to select all the packages in one shot.</li>"
msgstr ""
"<li><b>Tout sélectionner</b> : si les paquetages sont filtrés pour les mises "
"à jour uniquement, ce bouton permet de sélectionner tous les paquetages en "
"une seule fois.</li>"

#: dnfdragora/helpinfo.py:242
msgid "<li><b>Quit</b>: exits from dnfdragora.</li></ul>"
msgstr "<li><b>Quitter</b> : Ferme dnfdragora.</li></ul>"

#: dnfdragora/helpinfo.py:252
msgid ""
"The History dialog shows packages that have been recently changed on the "
"system by querying the dnf5daemon History API.<br><br>"
msgstr ""

#: dnfdragora/helpinfo.py:253
msgid "<h2>Opening the dialog</h2>"
msgstr ""

#: dnfdragora/helpinfo.py:254
msgid "Open the dialog from the menu bar: <b>Actions → History</b>.<br>"
msgstr ""

#: dnfdragora/helpinfo.py:255
msgid ""
"The main dnfdragora window is disabled while the dialog is open to prevent "
"unintended interactions.<br><br>"
msgstr ""

#: dnfdragora/helpinfo.py:257
msgid ""
"The <b>Filters</b> section at the top of the dialog lets you narrow the "
"results:<br>"
msgstr ""

#: dnfdragora/helpinfo.py:259
msgid ""
"<li><b>Since (YYYY-MM-DD)</b>: enter a date to show only packages changed on "
"or after that date. "
msgstr ""

#: dnfdragora/helpinfo.py:260
msgid "Leave empty to retrieve all available history. "
msgstr ""

#: dnfdragora/helpinfo.py:261
msgid ""
"The date is converted to a Unix timestamp before being sent to the daemon.</"
"li>"
msgstr ""

#: dnfdragora/helpinfo.py:263
msgid "<h2>Change type checkboxes</h2>"
msgstr ""

#: dnfdragora/helpinfo.py:264
msgid ""
"Four checkboxes let you choose which kinds of package changes to include in "
"the results:<br>"
msgstr ""

#: dnfdragora/helpinfo.py:266
msgid "<li><b>Installed</b>: packages that were newly installed.</li>"
msgstr ""

#: dnfdragora/helpinfo.py:267
msgid "<li><b>Removed</b>: packages that were removed from the system.</li>"
msgstr ""

#: dnfdragora/helpinfo.py:268
msgid ""
"<li><b>Upgraded</b>: packages that were upgraded to a newer version.</li>"
msgstr ""

#: dnfdragora/helpinfo.py:269
msgid ""
"<li><b>Downgraded</b>: packages that were downgraded to an older version.</"
"li>"
msgstr ""

#: dnfdragora/helpinfo.py:271
msgid ""
"Uncheck any type you are not interested in to reduce the number of rows "
"shown.<br><br>"
msgstr ""

#: dnfdragora/helpinfo.py:272
msgid "<h2>Advisory options</h2>"
msgstr ""

#: dnfdragora/helpinfo.py:274
msgid ""
"<li><b>Include advisories</b>: when checked, advisory information (security, "
"bugfix, enhancement) is included where available.</li>"
msgstr ""

#: dnfdragora/helpinfo.py:275
msgid ""
"<li><b>All advisories</b>: when checked together with <i>Include advisories</"
"i>, all advisory types are returned rather than only the most relevant one "
"per package. "
msgstr ""

#: dnfdragora/helpinfo.py:276
msgid ""
"This option is automatically disabled when <i>Include advisories</i> is "
"unchecked.</li>"
msgstr ""

#: dnfdragora/helpinfo.py:278
msgid "<h2>Results table</h2>"
msgstr ""

#: dnfdragora/helpinfo.py:279
msgid ""
"The table shows one row per changed package with the following columns:<br>"
msgstr ""

#: dnfdragora/helpinfo.py:281
msgid "<li><b>Name</b>: the package name.</li>"
msgstr ""

#: dnfdragora/helpinfo.py:282
msgid ""
"<li><b>EVR</b>: epoch:version-release of the new (installed) version.</li>"
msgstr ""

#: dnfdragora/helpinfo.py:283
msgid "<li><b>Arch</b>: the package architecture.</li>"
msgstr ""

#: dnfdragora/helpinfo.py:284
msgid ""
"<li><b>Action</b>: one of <i>installed</i>, <i>removed</i>, <i>upgraded</i>, "
"or <i>downgraded</i>.</li>"
msgstr ""

#: dnfdragora/helpinfo.py:285
msgid ""
"<li><b>Date</b>: the date and time of the transaction (YYYY-MM-DD HH:MM).</"
"li>"
msgstr ""

#: dnfdragora/helpinfo.py:286
msgid "<li><b>Summary</b>: a short description of the package.</li>"
msgstr ""

#: dnfdragora/helpinfo.py:288
msgid ""
"If no packages match the current filters a <i>No results</i> row is shown."
"<br>"
msgstr ""

#: dnfdragora/helpinfo.py:289
msgid ""
"If the daemon call fails the error message is displayed in the table so you "
"can diagnose the problem.<br><br>"
msgstr ""

#: dnfdragora/helpinfo.py:290
msgid "<h2>Refresh button</h2>"
msgstr ""

#: dnfdragora/helpinfo.py:291
msgid ""
"Press <b>Refresh</b> to re-query the daemon with the current filter "
"settings. "
msgstr ""

#: dnfdragora/helpinfo.py:292
msgid "The dialog also queries automatically when it first opens.<br><br>"
msgstr ""

#: dnfdragora/helpinfo.py:293
msgid "<h2>Close button</h2>"
msgstr ""

#: dnfdragora/helpinfo.py:294
msgid ""
"Press <b>Close</b> (or the window close button) to dismiss the dialog and "
"return to the main window.<br>"
msgstr ""

