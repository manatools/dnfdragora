#: ./share/applications/org.mageia.dnfdragora.desktop
msgctxt "Name"
msgid "dnfdragora"
msgstr "dnfdragora"

#: ./share/applications/org.mageia.dnfdragora.desktop
msgctxt "GenericName"
msgid "Install & Remove Software"
msgstr "Instal·leu i suprimiu programari"

#: ./share/applications/org.mageia.dnfdragora.desktop
msgctxt "Comment"
msgid "A graphical front end for installing, removing and updating packages"
msgstr "Una interfície gràfica per instal·lar, suprimir i actualitzar paquets"

#: ./share/applications/org.mageia.dnfdragora.desktop
msgctxt "Keywords"
msgid ""
"package;program;software;apps;applications;store;repository;add;install;uninstall;remove;delete;update;upgrade;"
msgstr ""
"paquet;programa;programari;aplicacions;emmagatzematge;repositori;afegir;instal·lar;desinstal·lar;eliminar;suprimir;actualitzar;millorar;"

#: ./share/applications/org.mageia.dnfdragora-updater.desktop
msgctxt "Name"
msgid "dnfdragora-updater"
msgstr "Actualitzador de dnfdragora"

#: ./share/applications/org.mageia.dnfdragora-updater.desktop
msgctxt "GenericName"
msgid "Tray-icon to check for updates"
msgstr "Icona per comprovar les actualitzacions"

#: ./share/applications/org.mageia.dnfdragora-updater.desktop
msgctxt "Comment"
msgid "Automatically check for updates and notify"
msgstr "Comprova automàticament si hi ha actualitzacions i notifica-m'ho"

#: ./share/applications/org.mageia.dnfdragora-localinstall.desktop
msgctxt "Name"
msgid "dnfdragora Package Installer"
msgstr "Instal·lador de paquets dnfdragora"

#: ./share/applications/org.mageia.dnfdragora-localinstall.desktop
msgctxt "GenericName"
msgid "RPM Package Installer"
msgstr "Instal·lador de paquets RPM"

#: ./share/applications/org.mageia.dnfdragora-localinstall.desktop
msgctxt "Comment"
msgid "Install local packages on the system"
msgstr "Instal·leu paquets locals al sistema"
