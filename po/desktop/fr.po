#: ./share/applications/org.mageia.dnfdragora.desktop
msgctxt "Name"
msgid "dnfdragora"
msgstr "dnfdragora"

#: ./share/applications/org.mageia.dnfdragora.desktop
msgctxt "GenericName"
msgid "Install & Remove Software"
msgstr "Installer et désinstaller des logiciels"

#: ./share/applications/org.mageia.dnfdragora.desktop
msgctxt "Comment"
msgid "A graphical front end for installing, removing and updating packages"
msgstr ""
"Une interface graphique pour installer, supprimer et mettre à jour les "
"paquetages"

#: ./share/applications/org.mageia.dnfdragora.desktop
msgctxt "Keywords"
msgid ""
"package;program;software;apps;applications;store;repository;add;install;uninstall;remove;delete;update;upgrade;"
msgstr ""
"paquet;paquetage;programme;application;magasin;dépôt;installer;ajouter;désinstaller;effacer;mettre"
" à jour;mettre à niveau;"

#: ./share/applications/org.mageia.dnfdragora-updater.desktop
msgctxt "Name"
msgid "dnfdragora-updater"
msgstr "dnfdragora-updater"

#: ./share/applications/org.mageia.dnfdragora-updater.desktop
msgctxt "GenericName"
msgid "Tray-icon to check for updates"
msgstr "Icône pour vérifier les mises à jour"

#: ./share/applications/org.mageia.dnfdragora-updater.desktop
msgctxt "Comment"
msgid "Automatically check for updates and notify"
msgstr "Vérifier automatiquement les mises à jour et me le faire savoir"

#: ./share/applications/org.mageia.dnfdragora-localinstall.desktop
msgctxt "Name"
msgid "dnfdragora Package Installer"
msgstr "Gestionnaire de logiciels dnfdragora"

#: ./share/applications/org.mageia.dnfdragora-localinstall.desktop
msgctxt "GenericName"
msgid "RPM Package Installer"
msgstr "Gestionnaire de paquetages RPM"

#: ./share/applications/org.mageia.dnfdragora-localinstall.desktop
msgctxt "Comment"
msgid "Install local packages on the system"
msgstr "Installer des paquetages locaux sur le système"
