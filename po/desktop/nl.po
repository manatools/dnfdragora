#: ./share/applications/org.mageia.dnfdragora.desktop
msgctxt "Name"
msgid "dnfdragora"
msgstr "dnfdragora"

#: ./share/applications/org.mageia.dnfdragora.desktop
msgctxt "GenericName"
msgid "Install & Remove Software"
msgstr "Software installeren & verwijderen"

#: ./share/applications/org.mageia.dnfdragora.desktop
msgctxt "Comment"
msgid "A graphical front end for installing, removing and updating packages"
msgstr ""
"Een grafische schil voor het installeren, verwijderen en bijwerken van "
"pakketten"

#: ./share/applications/org.mageia.dnfdragora.desktop
msgctxt "Keywords"
msgid ""
"package;program;software;apps;applications;store;repository;add;install;uninstall;remove;delete;update;upgrade;"
msgstr ""
"pakket;programma;software;apps;applicaties;opslaan;pakketdepot;toevoegen;installeren;de-"
"installeren;verwijderen;wissen;herziening;opwaardering;"

#: ./share/applications/org.mageia.dnfdragora-updater.desktop
msgctxt "Name"
msgid "dnfdragora-updater"
msgstr "dnfdragora-bijwerker"

#: ./share/applications/org.mageia.dnfdragora-updater.desktop
msgctxt "GenericName"
msgid "Tray-icon to check for updates"
msgstr "Taakbalk-pictogram om te controleren op herzieningen"

#: ./share/applications/org.mageia.dnfdragora-updater.desktop
msgctxt "Comment"
msgid "Automatically check for updates and notify"
msgstr "Automatisch controleren op herzieningen en dit melden"

#: ./share/applications/org.mageia.dnfdragora-localinstall.desktop
msgctxt "Name"
msgid "dnfdragora Package Installer"
msgstr "dnfdragora pakket-installatieprogramma"

#: ./share/applications/org.mageia.dnfdragora-localinstall.desktop
msgctxt "GenericName"
msgid "RPM Package Installer"
msgstr "RPM pakket-installatieprogramma"

#: ./share/applications/org.mageia.dnfdragora-localinstall.desktop
msgctxt "Comment"
msgid "Install local packages on the system"
msgstr "Installeer lokale pakketten op het systeem"
